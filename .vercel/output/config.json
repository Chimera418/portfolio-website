{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/ascii/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/clicker/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/fonts/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/guestbook/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/spotify/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/steam/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/devlog/?$",
			"dest": "_render"
		},
		{
			"src": "^/games/?$",
			"dest": "_render"
		},
		{
			"src": "^/guestbook/?$",
			"dest": "_render"
		},
		{
			"src": "^/labs/?$",
			"dest": "_render"
		},
		{
			"src": "^/projects/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/projects/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}