---
import BentoCard from './BentoCard.astro';
import Button from './Button.astro';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<BentoCard title="About" className={className} tag="SYS_INFO">
  <div class="flex flex-col justify-between h-full space-y-4">
    <div class="space-y-4">
      <p class="text-text-muted text-sm leading-relaxed">
        CSE-AI student passionate about <span class="text-secondary">full-stack development</span>, <span class="text-secondary">cybersecurity</span>, and building unconventional projects. I enjoy exploring how systems work, finding ways to break them, and finding increasingly elaborate ways to avoid repetitive work.
      </p>
      <p class="text-text-muted text-sm leading-relaxed">
        Half my projects start as experiments. The other half started as experiments too.
      </p>
    </div>
    <div class="mt-4 flex justify-end border-t border-highlight-med/30 pt-4">
      <a href="/about" class="text-text-muted hover:text-primary text-[10px] font-pixel uppercase tracking-wider transition-colors flex items-center gap-1 group/link">
        Read More
        <svg class="w-3 h-3 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </div>
</BentoCard>
