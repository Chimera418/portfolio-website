---

<BentoCard title="Connect" className={`${className || ''} group/bento relative hover:border-primary/50 transition-colors duration-300`} tag="NETWORK">
  <!-- Invisible overlay link to /contact -->
  <a href="/contact" class="absolute inset-0 z-0" aria-label="Go to Contact Page"></a>
  
  <div class="flex flex-col h-full justify-center gap-2 pt-1 relative z-10 pointer-events-none">
    {links.map(link => (
      <a
        href={link.href}
        target="_blank" 
        rel="noopener noreferrer"
        data-discord={link.discord ? 'true' : undefined}
        class="connect-link group flex items-center gap-3 px-3 py-2.5 rounded-xl border-2 border-transparent transition-all duration-200 hover:border-white/10 pointer-events-auto"
        style={`--link-color: ${link.color}; --link-bg: ${link.hoverBg};`}
      >
        <!-- Icon -->
        <div class="link-icon text-text-muted group-hover:text-[var(--link-color)] transition-colors duration-200" set:html={link.icon} />

        <!-- Text -->
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-text-primary group-hover:text-[var(--link-color)] transition-colors duration-200 leading-tight">{link.name}</p>
          <p class="text-[10px] font-pixel text-text-muted leading-tight mt-0.5 truncate">{link.hint}</p>
        </div>

        <!-- Arrow -->
        <svg class="w-4 h-4 text-text-muted group-hover:text-[var(--link-color)] group-hover:translate-x-0.5 transition-all duration-200 flex-shrink-0 opacity-0 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    ))}
  </div>
</BentoCard>

<style>
  .connect-link:hover {
    background-color: var(--link-bg);
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-discord="true"]').forEach(el => {
    el.addEventListener('click', (e) => {
      navigator.clipboard.writeText('gamingchimera').catch(() => {});
      
      const hintEl = el.querySelector('p:nth-of-type(2)');
      if (hintEl) {
        const originalText = hintEl.textContent;
        hintEl.textContent = 'copied!';
        hintEl.classList.add('text-primary');
        hintEl.classList.remove('text-text-muted');
        
        setTimeout(() => {
          hintEl.textContent = originalText;
          hintEl.classList.remove('text-primary');
          hintEl.classList.add('text-text-muted');
        }, 2000);
      }
    });
  });
</script>
