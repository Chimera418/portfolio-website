---
import BentoCard from "./BentoCard.astro";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<BentoCard title="System Manual" className={className} tag="DOCS">
  <div class="flex flex-col h-full justify-center gap-4">
    <div class="space-y-4">
      <div class="flex items-start gap-3">
        <div
          class="bg-surface-dim border border-highlight-med rounded p-1.5 mt-0.5 shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
            ><polyline points="4 17 10 11 4 5"></polyline><line
              x1="12"
              y1="19"
              x2="20"
              y2="19"></line></svg
          >
        </div>
        <div>
          <p
            class="text-xs text-text-primary font-bold font-pixel tracking-wide uppercase"
          >
            Command Palette
          </p>
          <p class="text-[10px] text-text-muted mt-1 leading-relaxed">
            Press <kbd
              class="bg-overlay px-1 py-0.5 rounded border border-highlight-med text-primary"
              >Ctrl</kbd
            > + <kbd
              class="bg-overlay px-1 py-0.5 rounded border border-highlight-med text-primary"
              >K</kbd
            > to access the system terminal anywhere.
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <div
          class="bg-surface-dim border border-highlight-med rounded p-1.5 mt-0.5 shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
            ><circle cx="12" cy="12" r="10"></circle><path
              d="M8 14s1.5 2 4 2 4-2 4-2"></path><line
              x1="9"
              y1="9"
              x2="9.01"
              y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg
          >
        </div>
        <div>
          <p
            class="text-xs text-text-primary font-bold font-pixel tracking-wide uppercase"
          >
            Easter Eggs
          </p>
          <p class="text-[10px] text-text-muted mt-1 leading-relaxed">
            Try entering the 
            <span tabindex="0" class="relative group/konami inline-block focus:outline-none">
              <span class="text-primary cursor-help border-b border-dashed border-primary/50 pb-[1px] hover:text-primary transition-colors">Konami code</span>
              <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-max opacity-0 group-hover/konami:opacity-100 group-focus/konami:opacity-100 transition-all duration-200 pointer-events-none z-50 translate-y-1 group-hover/konami:translate-y-0 group-focus/konami:translate-y-0">
                <span class="bg-overlay border border-highlight-med rounded-md px-2 py-1.5 shadow-xl shadow-black/50 backdrop-blur-sm flex gap-1">
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-text-primary"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg></kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-text-primary"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg></kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-text-primary"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg></kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-text-primary"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg></kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-text-primary"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg></kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-text-primary"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-text-primary"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg></kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-text-primary"><svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-[9px] font-sans font-bold text-text-primary">B</kbd>
                  <kbd class="bg-surface border border-highlight-med rounded w-4 h-4 flex items-center justify-center text-[9px] font-sans font-bold text-text-primary">A</kbd>
                </span>
                <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-overlay border-r border-b border-highlight-med rotate-45"></span>
              </span>
            </span>
            somewhere on any page. Also, <span class="text-primary"
              >clicking the clicker button</span
            > enough times might reveal some secret pages.
          </p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <div
          class="bg-surface-dim border border-highlight-med rounded p-1.5 mt-0.5 shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
            ><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"
            ></circle><circle cx="18" cy="16" r="3"></circle></svg
          >
        </div>
        <div>
          <p
            class="text-xs text-text-primary font-bold font-pixel tracking-wide uppercase"
          >
            Discoveries
          </p>
          <p class="text-[10px] text-text-muted mt-1 leading-relaxed">
            There might be something waiting on the <a
              href="/404"
              class="text-primary hover:underline">404 error page</a
            >. Also, try clicking on the <span class="text-primary"
              >profile picture</span
            > to listen to some pretty cool 
            <span tabindex="0" class="relative group/ost inline-block focus:outline-none">
              <span class="text-primary cursor-help border-b border-dashed border-primary/50 pb-[1px] hover:text-primary transition-colors">OST!</span>
              <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-max opacity-0 group-hover/ost:opacity-100 group-focus/ost:opacity-100 transition-all duration-200 pointer-events-none z-50 translate-y-1 group-hover/ost:translate-y-0 group-focus/ost:translate-y-0">
                <span class="bg-overlay border border-highlight-med rounded-md px-2.5 py-1.5 shadow-xl shadow-black/50 backdrop-blur-sm block">
                  <span class="text-[10px] font-bold text-text-primary tracking-wide whitespace-nowrap">Voice of no Return - NieR: Automata</span>
                </span>
                <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-overlay border-r border-b border-highlight-med rotate-45"></span>
              </span>
            </span>
          </p>
        </div>
      </div>
    </div>
  </div>
</BentoCard>
