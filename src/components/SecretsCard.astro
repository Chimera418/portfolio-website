---
import BentoCard from './BentoCard.astro';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<BentoCard title="System Manual" className={className} tag="DOCS">
  <div class="flex flex-col h-full justify-center gap-4">
    <div class="space-y-4">
      <div class="flex items-start gap-3">
        <div class="bg-surface-dim border border-highlight-med rounded p-1.5 mt-0.5 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
        </div>
        <div>
          <p class="text-xs text-text-primary font-bold font-pixel tracking-wide uppercase">Command Palette</p>
          <p class="text-[10px] text-text-muted mt-1 leading-relaxed">Press <kbd class="bg-overlay px-1 py-0.5 rounded border border-highlight-med text-secondary">Ctrl</kbd> + <kbd class="bg-overlay px-1 py-0.5 rounded border border-highlight-med text-secondary">K</kbd> to access the system terminal anywhere.</p>
        </div>
      </div>
      
      <div class="flex items-start gap-3">
        <div class="bg-surface-dim border border-highlight-med rounded p-1.5 mt-0.5 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>
        </div>
        <div>
          <p class="text-xs text-text-primary font-bold font-pixel tracking-wide uppercase">Easter Eggs</p>
          <p class="text-[10px] text-text-muted mt-1 leading-relaxed">
            Try entering the <span class="text-secondary">Konami code</span> somewhere on any page. Also, <span class="text-secondary">clicking the clicker button</span> enough times might reveal some secret pages — around 30 should do it.
          </p>
        </div>
      </div>
    </div>
  </div>
</BentoCard>
