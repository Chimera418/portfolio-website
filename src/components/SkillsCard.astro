---
import BentoCard from './BentoCard.astro';

interface Props {
  class?: string;
  style?: string;
}
const { class: className, style } = Astro.props;

const skills = [
  "Python", "TypeScript", "React", "Next.js",
  "Astro", "Tailwind CSS", "Node.js", "FastAPI",
  "Linux", "Docker", "Burp Suite", "Git"
];
---
<BentoCard title="Skills" className={className} style={style} tag="TECH_STACK">
  <div class="flex flex-col h-full justify-between">
    <div class="flex flex-wrap gap-2 pt-2">
      {skills.map(skill => (
        <span class="px-2.5 py-1 bg-primary/10 border border-primary/20 rounded text-[9px] text-primary font-pixel uppercase tracking-wider hover:bg-primary/20 hover:border-primary/40 transition-all duration-150 cursor-default">
          {skill}
        </span>
      ))}
    </div>
    <div class="mt-4 flex justify-end border-t border-highlight-med/30 pt-4">
      <a href="/about#skills" class="text-text-muted hover:text-primary text-[10px] font-pixel uppercase tracking-wider transition-colors flex items-center gap-1 group/link">
        Full Loadout
        <svg class="w-3 h-3 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </div>
</BentoCard>
