---
import BentoCard from "./BentoCard.astro";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<BentoCard title="Don't Judge Me" className={className} tag="SPOTIFY_API">
  <div class="flex flex-col justify-between h-full relative z-10 pt-1 gap-4">
    <!-- Album art + track info -->
    <div class="flex items-center gap-4">
      <div
        id="spotify-image"
        class="h-16 w-16 md:h-20 md:w-20 rounded-lg shadow-[2px_2px_0_rgba(0,0,0,0.5)] bg-overlay border border-highlight-med flex items-center justify-center text-xs text-text-muted font-pixel overflow-hidden flex-shrink-0"
      >
        <span class="animate-pulse">...</span>
      </div>
      <div class="flex-1 min-w-0 flex flex-col justify-center gap-1">
        <h4
          id="spotify-track"
          class="font-bold text-text-primary text-sm md:text-base truncate"
        >
          Connecting...
        </h4>
        <p
          id="spotify-artist"
          class="text-text-muted text-xs md:text-sm truncate"
        >
          Establishing link to Spotify API
        </p>
        <!-- Status pill inline with track info -->
        <div class="flex items-center gap-1.5 mt-0.5">
          <span
            id="spotify-status-dot"
            class="w-1.5 h-1.5 rounded-full bg-text-muted flex-shrink-0 -translate-y-[1px]"
          ></span>
          <span
            id="spotify-status-text"
            class="font-pixel text-[9px] uppercase tracking-widest text-text-muted"
            >Offline</span
          >
        </div>
      </div>
    </div>

    <!-- Listen CTA -->
    <a
      id="spotify-link"
      href="#"
      target="_blank"
      rel="noopener"
      class="flex items-center justify-between gap-3 w-full px-4 py-2.5 rounded-lg border-2 border-highlight-med bg-overlay hover:bg-surface hover:border-[#1db954] transition-all duration-200 group"
    >
      <div class="flex items-center gap-2 min-w-0">
        <!-- Spotify logo -->
        <svg
          class="w-4 h-4 flex-shrink-0 text-[#1db954]"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
          ></path>
        </svg>
        <span
          id="spotify-listen-text"
          class="font-pixel text-[10px] uppercase tracking-widest text-text-muted group-hover:text-[#1db954] transition-colors truncate"
          >Listen on Spotify</span
        >
      </div>
      <svg
        class="w-3.5 h-3.5 text-text-muted group-hover:text-[#1db954] group-hover:translate-x-0.5 transition-all flex-shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <path d="M7 17L17 7M17 7H7M17 7v10"></path>
      </svg>
    </a>
  </div>
</BentoCard>

<script is:inline>
  (function () {
    let lastFetch = 0;
    const FETCH_INTERVAL = 30000;

    function updateSpotifyCard(data) {
      const imageEl = document.getElementById("spotify-image");
      const trackEl = document.getElementById("spotify-track");
      const artistEl = document.getElementById("spotify-artist");
      const statusDot = document.getElementById("spotify-status-dot");
      const statusText = document.getElementById("spotify-status-text");
      const linkEl = document.getElementById("spotify-link");
      const listenText = document.getElementById("spotify-listen-text");

      if (!data || !data.track) {
        if (trackEl) trackEl.textContent = "System Idle";
        if (artistEl) artistEl.textContent = "No music playing";
        if (imageEl)
          imageEl.innerHTML =
            '<span class="text-text-muted font-pixel text-[10px]">IDLE</span>';
        if (statusDot)
          statusDot.className =
            "w-1.5 h-1.5 rounded-full bg-text-muted flex-shrink-0 -translate-y-[1px]";
        if (statusText) {
          statusText.textContent = "Offline";
          statusText.className =
            "font-pixel text-[9px] uppercase tracking-widest text-text-muted";
        }
        if (listenText) listenText.textContent = "Listen on Spotify";
        return;
      }

      const track = data.track;

      if (trackEl) trackEl.textContent = track.name;
      if (artistEl) artistEl.textContent = track.artist;

      if (imageEl && track.image) {
        imageEl.innerHTML = `<img src="${track.image}" alt="${track.name}" class="w-full h-full object-cover">`;
      }

      if (statusDot)
        statusDot.className =
          "w-1.5 h-1.5 rounded-full bg-[#1db954] flex-shrink-0 -translate-y-[1px]";
      if (statusText) {
        statusText.textContent = "Last Played";
        statusText.className =
          "font-pixel text-[9px] uppercase tracking-widest text-[#1db954]";
      }
      if (listenText) listenText.textContent = "Listen on Spotify";

      if (linkEl && track.url) linkEl.href = track.url;
    }

    async function fetchSpotifyData() {
      try {
        const now = Date.now();
        if (now - lastFetch < FETCH_INTERVAL) return;
        lastFetch = now;

        const response = await fetch("/api/spotify");
        if (response.ok) {
          const data = await response.json();
          updateSpotifyCard(data);
          return;
        }
        throw new Error("Failed to fetch");
      } catch (error) {
        console.error("Error fetching Spotify data:", error);
        const trackEl = document.getElementById("spotify-track");
        const artistEl = document.getElementById("spotify-artist");
        if (trackEl) trackEl.textContent = "ERR_CONNECTION";
        if (artistEl) artistEl.textContent = "Spotify API unreachable";
      }
    }

    fetchSpotifyData();
    setInterval(fetchSpotifyData, FETCH_INTERVAL);

    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) fetchSpotifyData();
    });
  })();
</script>
