---
interface Props {
  date: string;
  title: string;
  description: string;
  isLeft?: boolean;
}
const { date, title, description, isLeft = false } = Astro.props;
---
<div class="relative flex flex-col md:flex-row items-center w-full mb-12 group">
  <!-- Mobile Node (Top aligned to match text) -->
  <div class="absolute left-[20px] top-7 w-2.5 h-2.5 rounded-full bg-surface border-2 border-primary group-hover:bg-primary transition-colors -translate-x-1/2 z-10 md:hidden"></div>

  <!-- Desktop Node (Center aligned) -->
  <div class="hidden md:block absolute left-1/2 top-1/2 w-2.5 h-2.5 rounded-full bg-surface border-2 border-primary group-hover:bg-primary transition-colors -translate-x-1/2 -translate-y-1/2 z-10"></div>

  <!-- Left Side (Desktop Only) -->
  <div class="hidden md:flex w-1/2 pr-10 justify-end">
    {isLeft && (
      <div class="flex flex-col items-end w-full max-w-md">
        <div class="font-pixel text-[10px] text-primary mb-2 opacity-80">{date}</div>
        <div class="bg-overlay border border-highlight-med/40 rounded-xl p-5 transition-colors w-full text-left hover:border-primary/40 relative">
          <h3 class="text-text-primary font-bold text-lg mb-1 relative z-10">{title}</h3>
          <p class="text-text-muted text-sm leading-relaxed relative z-10">{description}</p>
        </div>
      </div>
    )}
  </div>

  <!-- Right Side (Also acts as Mobile Container) -->
  <div class="w-full md:w-1/2 pl-12 md:pl-10 flex justify-start">
    {/* Mobile Only Rendering */}
    <div class="md:hidden flex flex-col items-start w-full">
      <div class="font-pixel text-[10px] text-primary mb-2 opacity-80">{date}</div>
      <div class="bg-overlay border border-highlight-med/40 rounded-xl p-5 transition-colors w-full text-left hover:border-primary/40 relative">
        <h3 class="text-text-primary font-bold text-lg mb-1 relative z-10">{title}</h3>
        <p class="text-text-muted text-sm leading-relaxed relative z-10">{description}</p>
      </div>
    </div>

    {/* Desktop Right Side Rendering */}
    {!isLeft && (
      <div class="hidden md:flex flex-col items-start w-full max-w-md">
        <div class="font-pixel text-[10px] text-primary mb-2 opacity-80">{date}</div>
        <div class="bg-overlay border border-highlight-med/40 rounded-xl p-5 transition-colors w-full text-left hover:border-primary/40 relative">
          <h3 class="text-text-primary font-bold text-lg mb-1 relative z-10">{title}</h3>
          <p class="text-text-muted text-sm leading-relaxed relative z-10">{description}</p>
        </div>
      </div>
    )}
  </div>
</div>
