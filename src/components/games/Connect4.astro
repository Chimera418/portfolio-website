---
---

<div id="connect4-container" class="w-full h-full flex flex-col items-center justify-center bg-surface p-4 relative select-none">
  <button id="c4-restart-btn" class="absolute top-4 right-4 p-2 bg-surface hover:bg-highlight-med rounded-full border border-highlight-med transition-colors z-30 text-primary" title="Restart Game">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
      <path d="M3 3v5h5"></path>
    </svg>
  </button>

  <div class="mb-4 flex flex-col items-center justify-center w-full max-w-md">
    <div class="font-pixel text-primary text-2xl mb-2">CONNECT 4</div>
    <div class="flex gap-2 relative z-30">
      <button class="c4-mode-btn px-2 py-1 text-[10px] font-pixel border border-highlight-high rounded bg-highlight-low text-text hover:bg-highlight-med active" data-mode="2p">2P</button>
      <button class="c4-mode-btn px-2 py-1 text-[10px] font-pixel border border-highlight-high rounded bg-highlight-low text-text hover:bg-highlight-med" data-mode="easy">EASY</button>
      <button class="c4-mode-btn px-2 py-1 text-[10px] font-pixel border border-highlight-high rounded bg-highlight-low text-text hover:bg-highlight-med" data-mode="hard">HARD</button>
    </div>
  </div>

  <div class="font-pixel text-text-muted text-sm mb-4 h-4" id="c4-status"></div>

  <div class="relative bg-surface-bright p-3 sm:p-4 rounded-xl border-4 border-highlight-med shadow-2xl overflow-hidden">
    <div id="c4-board" class="relative grid grid-cols-7 gap-2 sm:gap-3 bg-surface-bright">
      <!-- 42 slots generated by JS -->
    </div>
    
    <!-- Overlay -->
    <div id="c4-overlay" class="absolute inset-0 bg-surface/80 backdrop-blur-sm flex flex-col items-center justify-center rounded-lg z-20">
      <h3 id="c4-result" class="font-pixel text-primary text-3xl mb-6 text-center drop-shadow-md">Connect 4</h3>
      <button id="c4-reset-btn" class="px-6 py-2 bg-primary/10 border-2 border-primary/50 text-primary hover:bg-primary/20 hover:border-primary rounded-lg font-pixel transition-colors">
        PLAY
      </button>
    </div>
  </div>
</div>

<style is:global>
  .c4-mode-btn.active {
    background-color: var(--color-primary);
    color: var(--color-surface);
    border-color: var(--color-primary);
  }

  #connect4-container .c4-slot {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--surface-dim);
    box-shadow: inset 0 3px 6px rgba(0,0,0,0.4);
    transition: background-color 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
  }
  @media (min-width: 640px) {
    #connect4-container .c4-slot {
      width: 3.5rem;
      height: 3.5rem;
    }
  }

  #connect4-container .c4-slot.red {
    background-color: #e63946;
    box-shadow: inset 0 -3px 6px rgba(0,0,0,0.3), 0 2px 4px rgba(230,57,70,0.4);
  }
  #connect4-container .c4-slot.yellow {
    background-color: #f4a261;
    box-shadow: inset 0 -3px 6px rgba(0,0,0,0.3), 0 2px 4px rgba(244,162,97,0.4);
  }
  #connect4-container .c4-slot.hover-red:hover:not(.red):not(.yellow) {
    background-color: rgba(230, 57, 70, 0.2);
  }
  #connect4-container .c4-slot.hover-yellow:hover:not(.red):not(.yellow) {
    background-color: rgba(244, 162, 97, 0.2);
  }
  #connect4-container .c4-slot.win-pulse {
    animation: c4WinPulse 1s infinite alternate;
  }

  @keyframes c4WinPulse {
    from { transform: scale(1); filter: brightness(1); }
    to   { transform: scale(1.1); filter: brightness(1.3); }
  }

  @keyframes c4GhostDrop {
    0%   { transform: translateY(var(--c4-drop-from, -400px)); }
    75%  { transform: translateY(4px); }
    88%  { transform: translateY(-3px); }
    100% { transform: translateY(0); }
  }

  /* Ghost element for smooth drops */
  .c4-ghost {
    position: absolute;
    border-radius: 50%;
    z-index: 10;
    pointer-events: none;
    box-shadow: inset 0 -3px 6px rgba(0,0,0,0.3), 0 2px 4px rgba(0,0,0,0.4);
    animation: c4GhostDrop var(--c4-drop-dur, 0.4s) ease-in forwards;
  }
  .c4-ghost.red {
    background-color: #e63946;
    box-shadow: inset 0 -3px 6px rgba(0,0,0,0.3), 0 2px 4px rgba(230,57,70,0.4);
  }
  .c4-ghost.yellow {
    background-color: #f4a261;
    box-shadow: inset 0 -3px 6px rgba(0,0,0,0.3), 0 2px 4px rgba(244,162,97,0.4);
  }
</style>

<script>
  const COLS = 7;
  const ROWS = 6;
  const EMPTY = 0;
  const RED = 1;
  const YELLOW = 2;

  let board = Array(ROWS).fill(null).map(() => Array(COLS).fill(EMPTY));
  let currentPlayer = RED;
  let gameActive = false;
  let mode = '2p';
  let isDropping = false;

  const container = document.getElementById('connect4-container');
  const boardEl = document.getElementById('c4-board');
  const statusEl = document.getElementById('c4-status');
  const overlay = document.getElementById('c4-overlay');
  const resultEl = document.getElementById('c4-result');
  const resetBtn = document.getElementById('c4-reset-btn');
  const restartBtn = document.getElementById('c4-restart-btn');
  const modeBtns = document.querySelectorAll('.c4-mode-btn');

  if (container && boardEl && statusEl && overlay && resultEl && resetBtn && restartBtn) {
    function showOverlay(title: string, btnLabel: string) {
      gameActive = false;
      resultEl!.textContent = title;
      resetBtn!.textContent = btnLabel;
      overlay!.style.display = 'flex';
    }

    function hideOverlay() {
      overlay!.style.display = 'none';
    }

    function goToStartScreen() {
      board = Array(ROWS).fill(null).map(() => Array(COLS).fill(EMPTY));
      statusEl!.textContent = '';
      updateUI();
      showOverlay('Connect 4', 'PLAY');
    }

    function initBoard() {
      boardEl!.innerHTML = '';
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          const slot = document.createElement('div');
          slot.className = 'c4-slot hover-red';
          slot.dataset.row = r.toString();
          slot.dataset.col = c.toString();
          slot.addEventListener('click', () => handleDrop(c));
          boardEl!.appendChild(slot);
        }
      }
    }

    function startGame() {
      board = Array(ROWS).fill(null).map(() => Array(COLS).fill(EMPTY));
      currentPlayer = RED;
      gameActive = true;
      statusEl!.textContent = "Red's Turn";
      statusEl!.style.color = '#e63946';
      updateUI();
      hideOverlay();
    }

    function getLowestEmptyRow(c: number): number {
      for (let r = ROWS - 1; r >= 0; r--) {
        if (board[r][c] === EMPTY) return r;
      }
      return -1;
    }

    function checkWin(player: number): { win: boolean, cells: [number, number][] } {
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          if (board[r][c] === player && board[r][c+1] === player && board[r][c+2] === player && board[r][c+3] === player)
            return { win: true, cells: [[r,c], [r,c+1], [r,c+2], [r,c+3]] };
        }
      }
      for (let r = 0; r < ROWS - 3; r++) {
        for (let c = 0; c < COLS; c++) {
          if (board[r][c] === player && board[r+1][c] === player && board[r+2][c] === player && board[r+3][c] === player)
            return { win: true, cells: [[r,c], [r+1,c], [r+2,c], [r+3,c]] };
        }
      }
      for (let r = 0; r < ROWS - 3; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          if (board[r][c] === player && board[r+1][c+1] === player && board[r+2][c+2] === player && board[r+3][c+3] === player)
            return { win: true, cells: [[r,c], [r+1,c+1], [r+2,c+2], [r+3,c+3]] };
        }
      }
      for (let r = 3; r < ROWS; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          if (board[r][c] === player && board[r-1][c+1] === player && board[r-2][c+2] === player && board[r-3][c+3] === player)
            return { win: true, cells: [[r,c], [r-1,c+1], [r-2,c+2], [r-3,c+3]] };
        }
      }
      return { win: false, cells: [] };
    }

    function checkDraw(): boolean {
      return board[0].every(c => c !== EMPTY);
    }

    function updateUI() {
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          const slot = boardEl!.children[r * COLS + c] as HTMLElement;
          slot.classList.remove('red', 'yellow', 'hover-red', 'hover-yellow', 'win-pulse');
          if (board[r][c] === RED) slot.classList.add('red');
          else if (board[r][c] === YELLOW) slot.classList.add('yellow');
          else if (gameActive) {
            slot.classList.add(currentPlayer === RED ? 'hover-red' : 'hover-yellow');
          }
        }
      }

      if (!gameActive) return; 

      statusEl!.textContent = currentPlayer === RED ? "Red's Turn" : "Yellow's Turn";
      statusEl!.style.color = currentPlayer === RED ? '#e63946' : '#f4a261';
    }

    function handleResult() {
      const redWin = checkWin(RED);
      const yellowWin = checkWin(YELLOW);
      
      if (redWin.win) {
        redWin.cells.forEach(([r, c]) => {
          boardEl!.children[r * COLS + c].classList.add('win-pulse');
        });
        statusEl!.textContent = 'Game Over';
        showOverlay('Red Wins!', 'PLAY AGAIN');
        return true;
      } else if (yellowWin.win) {
        yellowWin.cells.forEach(([r, c]) => {
          boardEl!.children[r * COLS + c].classList.add('win-pulse');
        });
        statusEl!.textContent = 'Game Over';
        showOverlay('Yellow Wins!', 'PLAY AGAIN');
        return true;
      } else if (checkDraw()) {
        statusEl!.textContent = 'Game Over';
        showOverlay('Draw!', 'PLAY AGAIN');
        return true;
      }
      return false;
    }

    function animateDrop(r: number, col: number, playerColor: number): number {
      const slotEl = boardEl!.children[r * COLS + col] as HTMLElement;
      
      // Briefly hide the actual slot color while the ghost falls
      slotEl.style.backgroundColor = 'var(--surface-dim)';
      slotEl.style.boxShadow = 'inset 0 3px 6px rgba(0,0,0,0.4)';

      // Create ghost element
      const ghost = document.createElement('div');
      ghost.className = `c4-ghost ${playerColor === RED ? 'red' : 'yellow'}`;
      
      // Match slot dimensions
      ghost.style.width = `${slotEl.offsetWidth}px`;
      ghost.style.height = `${slotEl.offsetHeight}px`;
      
      // Calculate final resting position relative to the board
      const boardRect = boardEl!.getBoundingClientRect();
      const slotRect = slotEl.getBoundingClientRect();
      
      const targetY = slotRect.top - boardRect.top;
      const targetX = slotRect.left - boardRect.left;
      
      // Set the ghost exactly at its final resting spot
      ghost.style.left = `${targetX}px`;
      ghost.style.top = `${targetY}px`;
      
      // The CSS animation will translate it from above the board down to 0
      // Calculate how far above it needs to start
      const startY = -(targetY + slotEl.offsetHeight + 20); // 20px extra just in case
      const dur = Math.min(0.25 + (r * 0.05), 0.5); 
      
      ghost.style.setProperty('--c4-drop-from', `${startY}px`);
      ghost.style.setProperty('--c4-drop-dur', `${dur}s`);
      
      // Cleanup on animation end
      ghost.addEventListener('animationend', () => {
        ghost.remove();
        // Restore actual slot styles
        slotEl.style.backgroundColor = '';
        slotEl.style.boxShadow = '';
      }, { once: true });

      // Fallback cleanup in case animationend fails
      setTimeout(() => {
        if (boardEl!.contains(ghost)) {
          ghost.remove();
          slotEl.style.backgroundColor = '';
          slotEl.style.boxShadow = '';
        }
      }, dur * 1000 + 100);

      boardEl!.appendChild(ghost);
      
      return dur * 1000;
    }

    function handleDrop(col: number) {
      if (!gameActive || isDropping) return;
      
      if (mode !== '2p' && currentPlayer === YELLOW) return;

      const r = getLowestEmptyRow(col);
      if (r === -1) return;

      isDropping = true;
      board[r][col] = currentPlayer;
      updateUI();          // colour the slot first
      const durMs = animateDrop(r, col, currentPlayer); // then play the drop on the coloured slot
      
      setTimeout(() => {
        isDropping = false;
        if (handleResult()) return;
        
        currentPlayer = currentPlayer === RED ? YELLOW : RED;
        updateUI();

        if (gameActive && mode !== '2p' && currentPlayer === YELLOW) {
          setTimeout(makeAIMove, 100);
        }
      }, durMs + 50); // add a tiny 50ms buffer to let ghost cleanup finish before overlay shows
    }

    // --- AI Logic ---
    function getValidLocations(b: number[][]): number[] {
      const valid = [];
      for (let c = 0; c < COLS; c++) {
        if (b[0][c] === EMPTY) valid.push(c);
      }
      return valid;
    }

    function makeAIMove() {
      if (!gameActive) return;
      let col = 0;
      
      if (mode === 'easy') {
        const valid = getValidLocations(board);
        col = valid[Math.floor(Math.random() * valid.length)];
      } else if (mode === 'hard') {
        col = minimax(board, 4, -Infinity, Infinity, true).col;
        if (col === -1) {
          const valid = getValidLocations(board);
          col = valid[Math.floor(Math.random() * valid.length)];
        }
      }

      const r = getLowestEmptyRow(col);
      if (r !== -1) {
        isDropping = true;
        board[r][col] = YELLOW;
        updateUI();          // colour first
        const durMs = animateDrop(r, col, YELLOW); // then animate
        
        setTimeout(() => {
          isDropping = false;
          if (handleResult()) return;
          currentPlayer = RED;
          updateUI();
        }, durMs + 50);
      }
    }

    function evaluateWindow(window: number[], piece: number): number {
      let score = 0;
      const oppPiece = piece === RED ? YELLOW : RED;
      let pieceCount = 0;
      let emptyCount = 0;
      let oppCount = 0;

      for (const cell of window) {
        if (cell === piece) pieceCount++;
        else if (cell === EMPTY) emptyCount++;
        else if (cell === oppPiece) oppCount++;
      }

      if (pieceCount === 4) score += 100;
      else if (pieceCount === 3 && emptyCount === 1) score += 5;
      else if (pieceCount === 2 && emptyCount === 2) score += 2;

      if (oppCount === 3 && emptyCount === 1) score -= 4;

      return score;
    }

    function scorePosition(b: number[][], piece: number): number {
      let score = 0;
      let centerCount = 0;
      for (let r = 0; r < ROWS; r++) {
        if (b[r][Math.floor(COLS/2)] === piece) centerCount++;
      }
      score += centerCount * 3;

      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          score += evaluateWindow([b[r][c], b[r][c+1], b[r][c+2], b[r][c+3]], piece);
        }
      }
      for (let c = 0; c < COLS; c++) {
        for (let r = 0; r < ROWS - 3; r++) {
          score += evaluateWindow([b[r][c], b[r+1][c], b[r+2][c], b[r+3][c]], piece);
        }
      }
      for (let r = 0; r < ROWS - 3; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          score += evaluateWindow([b[r][c], b[r+1][c+1], b[r+2][c+2], b[r+3][c+3]], piece);
        }
      }
      for (let r = 3; r < ROWS; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          score += evaluateWindow([b[r][c], b[r-1][c+1], b[r-2][c+2], b[r-3][c+3]], piece);
        }
      }
      return score;
    }

    function checkWinForBoard(b: number[][], player: number): boolean {
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          if (b[r][c] === player && b[r][c+1] === player && b[r][c+2] === player && b[r][c+3] === player) return true;
        }
      }
      for (let r = 0; r < ROWS - 3; r++) {
        for (let c = 0; c < COLS; c++) {
          if (b[r][c] === player && b[r+1][c] === player && b[r+2][c] === player && b[r+3][c] === player) return true;
        }
      }
      for (let r = 0; r < ROWS - 3; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          if (b[r][c] === player && b[r+1][c+1] === player && b[r+2][c+2] === player && b[r+3][c+3] === player) return true;
        }
      }
      for (let r = 3; r < ROWS; r++) {
        for (let c = 0; c < COLS - 3; c++) {
          if (b[r][c] === player && b[r-1][c+1] === player && b[r-2][c+2] === player && b[r-3][c+3] === player) return true;
        }
      }
      return false;
    }

    function isTerminalNode(b: number[][]): boolean {
      return checkWinForBoard(b, RED) || checkWinForBoard(b, YELLOW) || getValidLocations(b).length === 0;
    }

    function minimax(b: number[][], depth: number, alpha: number, beta: number, maximizingPlayer: boolean): {col: number, score: number} {
      const validLocs = getValidLocations(b);
      const isTerminal = isTerminalNode(b);
      if (depth === 0 || isTerminal) {
        if (isTerminal) {
          if (checkWinForBoard(b, YELLOW)) return { col: -1, score: 10000000 };
          else if (checkWinForBoard(b, RED)) return { col: -1, score: -10000000 };
          else return { col: -1, score: 0 };
        } else {
          return { col: -1, score: scorePosition(b, YELLOW) };
        }
      }

      if (maximizingPlayer) {
        let value = -Infinity;
        let bestCol = validLocs[Math.floor(Math.random() * validLocs.length)];
        for (const col of validLocs) {
          const r = getLowestRowForBoard(b, col);
          const bCopy = b.map(row => [...row]);
          bCopy[r][col] = YELLOW;
          const newScore = minimax(bCopy, depth - 1, alpha, beta, false).score;
          if (newScore > value) {
            value = newScore;
            bestCol = col;
          }
          alpha = Math.max(alpha, value);
          if (alpha >= beta) break;
        }
        return { col: bestCol, score: value };
      } else {
        let value = Infinity;
        let bestCol = validLocs[Math.floor(Math.random() * validLocs.length)];
        for (const col of validLocs) {
          const r = getLowestRowForBoard(b, col);
          const bCopy = b.map(row => [...row]);
          bCopy[r][col] = RED;
          const newScore = minimax(bCopy, depth - 1, alpha, beta, true).score;
          if (newScore < value) {
            value = newScore;
            bestCol = col;
          }
          beta = Math.min(beta, value);
          if (alpha >= beta) break;
        }
        return { col: bestCol, score: value };
      }
    }

    function getLowestRowForBoard(b: number[][], c: number): number {
      for (let r = ROWS - 1; r >= 0; r--) {
        if (b[r][c] === EMPTY) return r;
      }
      return -1;
    }

    modeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        modeBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        mode = (btn as HTMLElement).dataset.mode ?? '2p';
        startGame();
      });
    });

    resetBtn.addEventListener('click', startGame);
    restartBtn.addEventListener('click', goToStartScreen);

    initBoard();
    goToStartScreen();
  }
</script>
