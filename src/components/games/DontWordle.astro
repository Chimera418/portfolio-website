---
// DontWordle.astro
---
<div class="w-full h-full flex flex-col items-center justify-start overflow-y-auto bg-surface p-4 relative" id="dw-container">
  <button id="dw-restart-btn" class="absolute top-4 right-4 p-2 bg-surface hover:bg-highlight-med rounded-full border border-highlight-med transition-colors z-20 text-primary" title="Restart Game">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
      <path d="M3 3v5h5"></path>
    </svg>
  </button>

  <div class="absolute top-4 left-4 font-pixel text-green text-sm z-20">
    Wins: <span id="dw-wins">0</span>
  </div>
  
  <div class="mb-4 flex flex-col items-center justify-center w-full max-w-[350px]">
    <div class="font-pixel text-primary text-2xl mb-1">Don't Wordle</div>
    <div class="font-pixel text-text-muted text-[10px] text-center mb-2 leading-tight">
      Guess valid 5-letter words.<br/>
      Follow constraints. DON'T guess the hidden word.
    </div>
    
    <div class="flex justify-between w-full px-2 mt-2">
      <div class="font-pixel text-secondary text-xs">Valid Words left: <span id="dw-valid-count">...</span></div>
      <div class="font-pixel text-tertiary text-xs">Undos: <span id="dw-undos">3</span></div>
    </div>
  </div>

  <div class="w-full max-w-4xl flex flex-col lg:flex-row items-center lg:items-start justify-center gap-8 px-4">
    
    <!-- Game Column -->
    <div class="relative w-full max-w-[350px] flex flex-col items-center gap-6">
      
      <div class="flex items-center justify-center gap-4 w-full">
        <!-- Grid -->
        <div id="dw-grid" class="grid grid-rows-6 gap-2">
          <!-- Generated by JS -->
        </div>
        
        <!-- Actions -->
        <div class="flex flex-col gap-4 justify-center">
          <button id="dw-undo-btn" class="px-2 py-3 bg-tertiary/10 border border-tertiary/50 text-tertiary hover:bg-tertiary/20 rounded-lg font-pixel text-[10px] disabled:opacity-50 disabled:cursor-not-allowed transition-colors h-14 w-14 flex items-center justify-center">
            UNDO
          </button>
          <button id="dw-hint-btn" class="px-2 py-3 bg-secondary/10 border border-secondary/50 text-secondary hover:bg-secondary/20 rounded-lg font-pixel text-[10px] disabled:opacity-50 disabled:cursor-not-allowed transition-colors h-14 w-14 flex items-center justify-center">
            HINT
          </button>
        </div>
      </div>
      
      <!-- Keyboard -->
      <div id="dw-keyboard" class="w-full max-w-[350px] flex flex-col gap-1 sm:gap-2 px-1">
        <!-- Generated by JS -->
      </div>

      <!-- Game Over / Start Overlay -->
      <div id="dw-overlay" class="absolute inset-0 bg-surface/90 backdrop-blur-sm flex flex-col items-center justify-center rounded-lg z-10 transition-opacity duration-300 -m-4">
        <h3 id="dw-result" class="font-pixel text-primary text-3xl mb-2 text-center">Don't Wordle</h3>
        <p id="dw-message" class="font-pixel text-text-muted text-sm mb-6 text-center max-w-[80%]">Guess valid words without hitting the target!</p>
        <button id="dw-reset-btn" class="px-6 py-2 bg-primary/10 border-2 border-primary/50 text-primary hover:bg-primary/20 hover:border-primary rounded-lg font-pixel transition-colors">
          PLAY
        </button>
      </div>
    </div>

    <!-- Hint Container -->
    <div id="dw-hint-container" class="hidden w-full max-w-[350px] p-4 bg-overlay border border-highlight-med/50 rounded-lg lg:sticky lg:top-8 h-fit">
      <div class="font-pixel text-primary text-sm mb-3 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2v20"/><path d="M12 12h8.5"/></svg>
        AI Solver
      </div>
      <div class="font-pixel text-secondary text-xs mb-3">Target Word: <span id="dw-hint-target" class="text-highlight-high tracking-widest uppercase"></span></div>
      <div class="font-pixel text-text-muted text-[10px] mb-2">Safe words to play:</div>
      <div id="dw-hint-words" class="flex flex-wrap gap-1.5 text-[10px] font-pixel text-text-muted max-h-[300px] overflow-y-auto"></div>
    </div>
    
    <!-- Toast Message -->
    <div id="dw-toast" class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-overlay border border-highlight-high text-text px-4 py-2 rounded shadow-lg font-pixel text-xs z-20 opacity-0 pointer-events-none transition-opacity">
      Message
    </div>

  </div>
</div>

<style is:global>
  .dw-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.35rem;
  }
  .dw-cell {
    width: 2.6rem;
    height: 2.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: bold;
    text-transform: uppercase;
    line-height: 1;
    padding-top: 4px;
    border: 2px solid var(--color-highlight-med);
    border-radius: 0.25rem;
    background-color: var(--color-overlay);
    transition: all 0.2s;
  }
  @media (max-width: 400px) {
    .dw-cell {
      width: 2.25rem;
      height: 2.25rem;
      font-size: 1rem;
    }
  }
  
  .dw-cell.filled { border-color: var(--color-highlight-high); }
  .dw-cell.green { background-color: #31748f; border-color: #31748f; color: white; } /* Pine */
  .dw-cell.yellow { background-color: #f6c177; border-color: #f6c177; color: #191724; } /* Gold */
  .dw-cell.gray { background-color: #524f67; border-color: #524f67; color: white; } /* Muted */

  .dw-key-row {
    display: flex;
    justify-content: center;
    gap: 0.25rem;
  }
  .dw-key {
    background-color: var(--color-highlight-med);
    color: var(--color-text);
    border-radius: 0.25rem;
    font-weight: bold;
    font-family: monospace;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    user-select: none;
    transition: all 0.2s;
    height: 2.5rem;
    flex: 1;
    max-width: 2.25rem;
  }
  @media (max-width: 400px) {
    .dw-key { height: 2rem; font-size: 0.75rem; }
  }
  .dw-key:hover { background-color: var(--color-highlight-high); }
  .dw-key.wide { max-width: 4rem; font-size: 0.7rem; }
  
  .dw-key.green { background-color: #31748f; color: white; }
  .dw-key.yellow { background-color: #f6c177; color: #191724; }
  .dw-key.gray { background-color: #524f67; color: white; opacity: 0.5; }
</style>

<script>
  import { VALID_WORDS } from '../../data/words';
  let dictionary: string[] = VALID_WORDS.map(w => w.toUpperCase());

  const container = document.getElementById('dw-container');
  if (container) {
    const gridEl = document.getElementById('dw-grid');
    const keyboardEl = document.getElementById('dw-keyboard');
    const overlay = document.getElementById('dw-overlay');
    const resultEl = document.getElementById('dw-result');
    const messageEl = document.getElementById('dw-message');
    const resetBtn = document.getElementById('dw-reset-btn');
    const validCountEl = document.getElementById('dw-valid-count');
    const winsEl = document.getElementById('dw-wins');
    const undosEl = document.getElementById('dw-undos');
    const undoBtn = document.getElementById('dw-undo-btn') as HTMLButtonElement;
    const hintBtn = document.getElementById('dw-hint-btn') as HTMLButtonElement;
    const hintContainer = document.getElementById('dw-hint-container');
    const hintTarget = document.getElementById('dw-hint-target');
    const hintWords = document.getElementById('dw-hint-words');
    const toastEl = document.getElementById('dw-toast');
    const restartBtn = document.getElementById('dw-restart-btn');

    const ROWS = 6;
    const COLS = 5;
    
    // State
    let targetWord = "";
    let guesses: string[] = [];
    let currentGuess = "";
    let validWords: string[] = [];
    let undosLeft = 3;
    let isGameOver = true;
    let wins = parseInt(localStorage.getItem('dw-wins') || '0');

    // Constraints tracking
    interface Constraints {
      greens: string[]; // length 5 array of char or ''
      yellows: {char: string, invalidPositions: number[]}[];
      grays: Set<string>;
      requiredLetters: Set<string>;
      maxCounts: Record<string, number>;
    }
    let constraints: Constraints = {
      greens: ['', '', '', '', ''],
      yellows: [],
      grays: new Set(),
      requiredLetters: new Set(),
      maxCounts: {}
    };

    // History for undo
    let history: {
      guesses: string[],
      validWords: string[],
      constraints: Constraints
    }[] = [];

    const keys = [
      ['Q','W','E','R','T','Y','U','I','O','P'],
      ['A','S','D','F','G','H','J','K','L'],
      ['ENTER','Z','X','C','V','B','N','M','BACK']
    ];

    function initGame() {
      targetWord = dictionary[Math.floor(Math.random() * dictionary.length)];
      guesses = [];
      currentGuess = "";
      validWords = [...dictionary];
      undosLeft = 3;
      isGameOver = false;
      constraints = {
        greens: ['', '', '', '', ''],
        yellows: [],
        grays: new Set(),
        requiredLetters: new Set(),
        maxCounts: {}
      };
      history = [];

      if (hintContainer) hintContainer.classList.add('hidden');

      buildGrid();
      buildKeyboard();
      updateUI();
      // wait for play click
    }

    function buildGrid() {
      if(!gridEl) return;
      gridEl.innerHTML = '';
      for (let r = 0; r < ROWS; r++) {
        const row = document.createElement('div');
        row.className = 'dw-row';
        for (let c = 0; c < COLS; c++) {
          const cell = document.createElement('div');
          cell.className = 'dw-cell font-pixel';
          cell.id = `dw-cell-${r}-${c}`;
          row.appendChild(cell);
        }
        gridEl.appendChild(row);
      }
    }

    function buildKeyboard() {
      if(!keyboardEl) return;
      keyboardEl.innerHTML = '';
      keys.forEach(rowKeys => {
        const row = document.createElement('div');
        row.className = 'dw-key-row';
        rowKeys.forEach(key => {
          const btn = document.createElement('button');
          btn.className = `dw-key ${key === 'ENTER' || key === 'BACK' ? 'wide' : ''}`;
          btn.textContent = key === 'BACK' ? '⌫' : key;
          btn.id = `dw-key-${key}`;
          btn.addEventListener('click', () => handleKeyPress(key));
          row.appendChild(btn);
        });
        keyboardEl.appendChild(row);
      });
    }

    function showToast(msg: string) {
      if(!toastEl) return;
      toastEl.textContent = msg;
      toastEl.style.opacity = '1';
      setTimeout(() => {
        toastEl.style.opacity = '0';
      }, 2000);
    }

    function handleKeyPress(key: string) {
      if (isGameOver) return;
      
      // Ensure container is visible
      const gameContainer = document.getElementById('game-content-dont-wordle');
      if (gameContainer && gameContainer.classList.contains('hidden')) return;

      if (key === 'ENTER') {
        submitGuess();
      } else if (key === 'BACK' || key === 'BACKSPACE') {
        if (currentGuess.length > 0) {
          currentGuess = currentGuess.slice(0, -1);
          updateGrid();
        }
      } else if (/^[A-Z]$/.test(key)) {
        if (currentGuess.length < COLS) {
          currentGuess += key;
          updateGrid();
        }
      }
    }

    function evaluateGuess(guess: string, target: string) {
      const result = Array(5).fill('gray');
      const targetArr = target.split('');
      const guessArr = guess.split('');

      // Pass 1: Greens
      for (let i = 0; i < 5; i++) {
        if (guessArr[i] === targetArr[i]) {
          result[i] = 'green';
          targetArr[i] = null as any;
          guessArr[i] = null as any;
        }
      }

      // Pass 2: Yellows
      for (let i = 0; i < 5; i++) {
        if (guessArr[i] !== null) {
          const targetIdx = targetArr.indexOf(guessArr[i]);
          if (targetIdx !== -1) {
            result[i] = 'yellow';
            targetArr[targetIdx] = null as any;
          }
        }
      }

      return result;
    }

    function updateConstraints(guess: string, evalResult: string[]) {
      const newConstraints = JSON.parse(JSON.stringify(constraints, (key, value) => {
        if (value instanceof Set) return [...value];
        return value;
      }));
      newConstraints.grays = new Set(newConstraints.grays);
      newConstraints.requiredLetters = new Set(newConstraints.requiredLetters);

      const guessGreenYellowCounts: Record<string, number> = {};
      for (let i = 0; i < 5; i++) {
        if (evalResult[i] === 'green' || evalResult[i] === 'yellow') {
          const char = guess[i];
          guessGreenYellowCounts[char] = (guessGreenYellowCounts[char] || 0) + 1;
        }
      }

      for (let i = 0; i < 5; i++) {
        const char = guess[i];
        if (evalResult[i] === 'green') {
          newConstraints.greens[i] = char;
          newConstraints.requiredLetters.add(char);
        } else if (evalResult[i] === 'yellow') {
          let existing = newConstraints.yellows.find((y: any) => y.char === char);
          if (existing) {
            if(!existing.invalidPositions.includes(i)) existing.invalidPositions.push(i);
          } else {
            newConstraints.yellows.push({char, invalidPositions: [i]});
          }
          newConstraints.requiredLetters.add(char);
        } else if (evalResult[i] === 'gray') {
          newConstraints.grays.add(char);
          newConstraints.maxCounts[char] = guessGreenYellowCounts[char] || 0;
        }
      }

      return newConstraints;
    }

    function checkConstraintsViolations(guess: string): string | null {
      // 1. Must use greens
      for (let i = 0; i < 5; i++) {
        if (constraints.greens[i] !== '' && guess[i] !== constraints.greens[i]) {
          return `Must use ${constraints.greens[i]} in position ${i + 1}`;
        }
      }

      // 2. Must use required letters (yellows)
      for (let reqChar of constraints.requiredLetters) {
        if (!guess.includes(reqChar)) {
          return `Guess must contain ${reqChar}`;
        }
      }

      // 3. Must not put yellows in invalid positions
      for (let i = 0; i < 5; i++) {
        const char = guess[i];
        const yellowRule = constraints.yellows.find(y => y.char === char);
        if (yellowRule && yellowRule.invalidPositions.includes(i)) {
          return `${char} cannot be in position ${i + 1}`;
        }
      }

      // 4. Check max counts (handles grays properly when there are duplicate letters)
      const guessCounts: Record<string, number> = {};
      for (let i = 0; i < 5; i++) {
        const char = guess[i];
        guessCounts[char] = (guessCounts[char] || 0) + 1;
      }
      
      for (let char in guessCounts) {
        if (constraints.maxCounts[char] !== undefined && guessCounts[char] > constraints.maxCounts[char]) {
           if (constraints.maxCounts[char] === 0) {
              return `Letter ${char} is gray and cannot be used`;
           }
           return `You already know there is only ${constraints.maxCounts[char]} ${char}`;
        }
      }

      return null;
    }

    function updateValidWords() {
      // Very basic filtering based on current constraints
      validWords = dictionary.filter(word => {
        // Must match greens
        for (let i = 0; i < 5; i++) {
          if (constraints.greens[i] !== '' && word[i] !== constraints.greens[i]) return false;
        }
        
        // Must have required
        for (let reqChar of constraints.requiredLetters) {
          if (!word.includes(reqChar)) return false;
        }
        
        // Yellows invalid pos
        for (let i = 0; i < 5; i++) {
          const char = word[i];
          const yellowRule = constraints.yellows.find(y => y.char === char);
          if (yellowRule && yellowRule.invalidPositions.includes(i)) return false;
        }
        
        // Max Counts (handles Grays and exact counts)
        const wordCounts: Record<string, number> = {};
        for (let i = 0; i < 5; i++) {
          const char = word[i];
          wordCounts[char] = (wordCounts[char] || 0) + 1;
        }
        for (let char in constraints.maxCounts) {
          if ((wordCounts[char] || 0) > constraints.maxCounts[char]) return false;
        }

        return true;
      });
      
      if(validCountEl) validCountEl.textContent = validWords.length.toString();
      
      // Update AI Solver dynamically if it's open
      if (hintContainer && !hintContainer.classList.contains('hidden') && hintTarget && hintWords) {
        hintTarget.textContent = targetWord;
        const safeWords = validWords.filter(w => w !== targetWord).slice(0, 100);
        if (safeWords.length === 0) {
           hintWords.innerHTML = '<span class="text-primary font-bold tracking-widest">No safe words found!</span>';
        } else {
           hintWords.innerHTML = safeWords.map(w => 
             `<span class="px-1.5 py-0.5 bg-highlight-high/20 border border-highlight-high/40 text-primary rounded tracking-widest uppercase">${w}</span>`
           ).join('');
        }
      }
    }

    function submitGuess() {
      if (currentGuess.length !== COLS) {
        showToast("Not enough letters");
        return;
      }
      
      if (!dictionary.includes(currentGuess)) {
        showToast("Not in word list");
        return;
      }

      const violation = checkConstraintsViolations(currentGuess);
      if (violation) {
        showToast(violation);
        return;
      }

      // Save state for undo
      history.push({
        guesses: [...guesses],
        validWords: [...validWords],
        constraints: JSON.parse(JSON.stringify(constraints, (k,v) => v instanceof Set ? [...v] : v))
      });

      // Evaluate
      const result = evaluateGuess(currentGuess, targetWord);
      
      // Update constraints
      const newConstraints = updateConstraints(currentGuess, result);
      constraints = newConstraints;

      guesses.push(currentGuess);
      currentGuess = "";

      updateGrid(result);
      updateKeyboard();
      updateValidWords();
      updateUI();

      // Check win/loss
      if (guesses[guesses.length - 1] === targetWord) {
        gameOver(false, "You guessed the word! You lose.");
      } else if (guesses.length >= ROWS) {
        // Survived
        gameOver(true, `You survived! The word was ${targetWord}.`);
      }
    }

    function updateGrid(lastEvalResult?: string[]) {
      // Draw previous guesses
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          const cell = document.getElementById(`dw-cell-${r}-${c}`);
          if (!cell) continue;
          
          if (r < guesses.length) {
            // Submitted row
            const word = guesses[r];
            cell.textContent = word[c];
            cell.classList.add('filled');
            
            // Only re-calculate eval if we are redrawing everything, else rely on CSS classes
            if (!cell.classList.contains('green') && !cell.classList.contains('yellow') && !cell.classList.contains('gray')) {
               const res = evaluateGuess(word, targetWord);
               cell.classList.add(res[c]);
            }
          } else if (r === guesses.length) {
            // Current typing row
            cell.textContent = currentGuess[c] || '';
            cell.className = `dw-cell font-pixel ${currentGuess[c] ? 'filled' : ''}`;
          } else {
            // Empty future row
            cell.textContent = '';
            cell.className = 'dw-cell font-pixel';
          }
        }
      }
    }

    function updateKeyboard() {
      // Basic coloring: green > yellow > gray
      const keyColors: Record<string, string> = {};
      
      for (let word of guesses) {
        const res = evaluateGuess(word, targetWord);
        for (let i = 0; i < 5; i++) {
          const char = word[i];
          const color = res[i];
          
          if (color === 'green') {
            keyColors[char] = 'green';
          } else if (color === 'yellow' && keyColors[char] !== 'green') {
            keyColors[char] = 'yellow';
          } else if (color === 'gray' && keyColors[char] !== 'green' && keyColors[char] !== 'yellow') {
            keyColors[char] = 'gray';
          }
        }
      }
      
      for (let char in keyColors) {
        const btn = document.getElementById(`dw-key-${char}`);
        if (btn) {
          btn.classList.remove('green', 'yellow', 'gray');
          btn.classList.add(keyColors[char]);
        }
      }
    }

    function updateUI() {
      if(undosEl) undosEl.textContent = undosLeft.toString();
      if(undoBtn) undoBtn.disabled = undosLeft === 0 || history.length === 0;
      if(validCountEl && guesses.length === 0) validCountEl.textContent = dictionary.length.toString();
      if(winsEl) winsEl.textContent = isNaN(wins) ? '0' : wins.toString();
    }

    function undo() {
      if (undosLeft > 0 && history.length > 0) {
        const prevState = history.pop()!;
        guesses = prevState.guesses;
        validWords = prevState.validWords;
        
        // Restore constraints (converting arrays back to Sets)
        constraints = prevState.constraints;
        constraints.grays = new Set(constraints.grays);
        constraints.requiredLetters = new Set(constraints.requiredLetters);
        
        currentGuess = "";
        undosLeft--;
        
        // Full redraw
        buildGrid();
        updateGrid();
        
        // Redraw keyboard colors
        keys.forEach(row => row.forEach(k => {
          const btn = document.getElementById(`dw-key-${k}`);
          if(btn) btn.classList.remove('green', 'yellow', 'gray');
        }));
        updateKeyboard();
        
        updateValidWords();
        updateUI();
      }
    }

    function gameOver(win: boolean, msg: string) {
      isGameOver = true;
      if (win) {
        wins = isNaN(wins) ? 1 : wins + 1;
        localStorage.setItem('dw-wins', wins.toString());
        updateUI();
      }
      if(resultEl) resultEl.textContent = win ? "You Won!" : "Game Over";
      if(messageEl) messageEl.textContent = msg;
      overlay?.classList.remove('hidden');
    }

    // Event Listeners
    document.addEventListener('keydown', (e) => {
      const gameContainer = document.getElementById('game-content-dont-wordle');
      if (gameContainer && gameContainer.classList.contains('hidden')) return;
      if (isGameOver) return;
      
      // Prevent default for backspace
      if (e.key === 'Backspace') {
        e.preventDefault();
        handleKeyPress('BACK');
      } else if (e.key === 'Enter') {
        handleKeyPress('ENTER');
      } else if (/^[a-zA-Z]$/.test(e.key) && e.key.length === 1) {
        handleKeyPress(e.key.toUpperCase());
      }
    });

    if(undoBtn) undoBtn.addEventListener('click', undo);
    
    if(hintBtn) hintBtn.addEventListener('click', () => {
      if (!hintContainer || isGameOver) return;
      hintContainer.classList.remove('hidden');
      updateValidWords(); // Will populate the list
    });
    if(resetBtn) resetBtn.addEventListener('click', () => {
      if (resetBtn.textContent?.trim() === 'PLAY') {
         overlay?.classList.add('hidden');
         isGameOver = false;
      } else {
         initGame();
         overlay?.classList.add('hidden');
      }
    });
    if(restartBtn) restartBtn.addEventListener('click', () => {
       initGame();
       isGameOver = true;
       if(resultEl) resultEl.textContent = "Don't Wordle";
       if(messageEl) messageEl.textContent = "Guess valid words without hitting the target!";
       if(resetBtn) resetBtn.textContent = 'PLAY';
       overlay?.classList.remove('hidden');
    });

    initGame();
    isGameOver = true; // wait for PLAY click
  }
</script>
