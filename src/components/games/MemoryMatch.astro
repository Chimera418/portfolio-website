---
// MemoryMatch.astro
---
<div class="w-full h-full flex flex-col items-center justify-center bg-surface p-4 relative" id="memory-container">
  <button id="memory-restart-btn" class="absolute top-4 right-4 p-2 bg-surface hover:bg-highlight-med rounded-full border border-highlight-med transition-colors z-20 text-primary" title="Restart Game">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
      <path d="M3 3v5h5"></path>
    </svg>
  </button>
  
  <div class="mb-6 flex items-center justify-between w-full max-w-[400px]">
    <div class="flex flex-col">
      <div class="font-pixel text-primary text-xl">MEMORY</div>
      <div class="font-pixel text-text-muted text-[10px]">Find all pairs</div>
    </div>
    <div class="flex gap-4">
      <div class="text-right">
        <div class="font-pixel text-text-muted text-[10px]">BEST</div>
        <div class="font-pixel text-primary text-lg" id="memory-best">-</div>
      </div>
      <div class="text-right">
        <div class="font-pixel text-text-muted text-[10px]">MOVES</div>
        <div class="font-pixel text-primary text-lg" id="memory-moves">0</div>
      </div>
      <div class="text-right">
        <div class="font-pixel text-text-muted text-[10px]">MATCHES</div>
        <div class="font-pixel text-primary text-lg" id="memory-matches">0/8</div>
      </div>
    </div>
  </div>

  <div class="relative w-full max-w-[400px] aspect-square">
    <div id="memory-grid" class="w-full h-full grid grid-cols-4 grid-rows-4 gap-2 sm:gap-3 perspective-1000">
      <!-- Cards generated by JS -->
    </div>
    
    <!-- Game Over Overlay -->
    <div id="memory-overlay" class="absolute inset-0 bg-surface/80 backdrop-blur-sm flex flex-col items-center justify-center rounded-lg z-10 transition-opacity duration-300">
      <h3 id="memory-title" class="font-pixel text-primary text-3xl mb-2 text-center">Ready?</h3>
      <p id="memory-stats" class="font-pixel text-text-muted text-sm mb-6 hidden">Completed in <span id="memory-final-moves" class="text-secondary">0</span> moves</p>
      <button id="memory-start-btn" class="px-6 py-2 bg-primary/10 border-2 border-primary/50 text-primary hover:bg-primary/20 hover:border-primary rounded-lg font-pixel transition-colors">
        START
      </button>
    </div>
  </div>

</div>

<style is:global>
  .perspective-1000 {
    perspective: 1000px;
  }
  
  .memory-card {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.4, 0.2, 0.2, 1);
    cursor: pointer;
  }
  
  .memory-card.flipped {
    transform: rotateY(180deg);
  }
  
  .memory-card.matched {
    transform: rotateY(180deg) scale(0.95);
  }
  
  .memory-card.matched .memory-card-front {
    opacity: 0.6;
    border-color: var(--color-highlight-high);
  }
  
  .memory-card-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
  }
  
  .memory-card-front {
    background-color: var(--color-overlay);
    border: 2px solid var(--color-highlight-med);
    transform: rotateY(180deg);
  }
  
  .memory-card-back {
    background-color: var(--color-highlight-low);
    border: 2px solid var(--color-highlight-med);
    transition: background-color 0.2s;
  }
  
  .memory-card:hover:not(.flipped) .memory-card-back {
    background-color: var(--color-highlight-med);
  }

  .memory-sprite {
    background-image: url("/combined_avatars.png");
    background-repeat: no-repeat;
    width: 32px;
    height: 32px;
    background-position: 0px calc(var(--sprite-idx) * -32px);
    image-rendering: pixelated;
    transform: scale(2); /* make them bigger for the cards */
  }

</style>

<script>
  const grid = document.getElementById('memory-grid');
  const movesEl = document.getElementById('memory-moves');
  const matchesEl = document.getElementById('memory-matches');
  const bestEl = document.getElementById('memory-best');
  const overlay = document.getElementById('memory-overlay');
  const title = document.getElementById('memory-title');
  const statsEl = document.getElementById('memory-stats');
  const finalMovesEl = document.getElementById('memory-final-moves');
  const startBtn = document.getElementById('memory-start-btn');
  const restartBtn = document.getElementById('memory-restart-btn');

  if (grid && movesEl && matchesEl && overlay && startBtn) {
    let cards: {id: number, iconId: number}[] = [];
    let moves = 0;
    let matches = 0;
    let bestMoves = parseInt(localStorage.getItem('memoryBestScore') || '0', 10);
    let flippedCards: HTMLElement[] = [];
    let isLocked = false;
    let isPlaying = false;

    // Pick 8 random distinct sprites from the 45 available
    function getRandomSpriteIndices() {
      const all = Array.from({length: 45}, (_, i) => i);
      for (let i = all.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [all[i], all[j]] = [all[j], all[i]];
      }
      return all.slice(0, 8);
    }

    function initGame() {
      // Create deck
      const spriteIndices = getRandomSpriteIndices();
      const deck = [...spriteIndices, ...spriteIndices].map((spriteIdx, index) => ({
        id: index,
        iconId: spriteIdx
      }));
      
      // Shuffle
      for (let i = deck.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [deck[i], deck[j]] = [deck[j], deck[i]];
      }
      
      // Reset state
      moves = 0;
      matches = 0;
      movesEl.textContent = '0';
      matchesEl.textContent = '0/8';
      if (bestEl) bestEl.textContent = bestMoves > 0 ? bestMoves.toString() : '-';
      flippedCards = [];
      isLocked = false;
      
      // Build UI
      grid.innerHTML = '';
      deck.forEach(card => {
        const cardEl = document.createElement('div');
        cardEl.className = 'memory-card';
        cardEl.dataset.id = card.id.toString();
        cardEl.dataset.iconId = card.iconId.toString();
        
        cardEl.innerHTML = `
          <div class="memory-card-face memory-card-back"></div>
          <div class="memory-card-face memory-card-front">
            <div class="memory-sprite" style="--sprite-idx: ${card.iconId};"></div>
          </div>
        `;
        
        cardEl.addEventListener('click', () => flipCard(cardEl));
        grid.appendChild(cardEl);
      });
    }

    function flipCard(cardEl: HTMLElement) {
      if (!isPlaying) return;
      if (isLocked) return;
      if (cardEl.classList.contains('flipped')) return;
      
      cardEl.classList.add('flipped');
      flippedCards.push(cardEl);
      
      if (flippedCards.length === 2) {
        moves++;
        movesEl.textContent = moves.toString();
        checkForMatch();
      }
    }

    function checkForMatch() {
      const [card1, card2] = flippedCards;
      const isMatch = card1.dataset.iconId === card2.dataset.iconId;
      
      if (isMatch) {
        disableCards();
      } else {
        unflipCards();
      }
    }

    function disableCards() {
      flippedCards[0].classList.add('matched');
      flippedCards[1].classList.add('matched');
      matches++;
      matchesEl.textContent = `${matches}/8`;
      
      flippedCards = [];
      
      if (matches === 8) {
        setTimeout(winGame, 500);
      }
    }

    function unflipCards() {
      isLocked = true;
      setTimeout(() => {
        flippedCards[0].classList.remove('flipped');
        flippedCards[1].classList.remove('flipped');
        flippedCards = [];
        isLocked = false;
      }, 1000);
    }

    function winGame() {
      isPlaying = false;
      title.textContent = 'YOU WIN!';
      startBtn.textContent = 'PLAY AGAIN';
      
      if (bestMoves === 0 || moves < bestMoves) {
        bestMoves = moves;
        localStorage.setItem('memoryBestScore', bestMoves.toString());
        if (bestEl) bestEl.textContent = bestMoves.toString();
      }
      
      window.dispatchEvent(new CustomEvent('arcade-game-over', { detail: { game: 'memory-match', score: moves } }));

      if (statsEl && finalMovesEl) {
        statsEl.classList.remove('hidden');
        finalMovesEl.textContent = moves.toString();
      }
      overlay.classList.remove('hidden');
    }

    startBtn.addEventListener('click', () => {
      overlay.classList.add('hidden');
      if (statsEl) statsEl.classList.add('hidden');
      initGame();
      isPlaying = true;
    });

    if (restartBtn) {
      restartBtn.addEventListener('click', () => {
        initGame();
        isPlaying = false;
        title.textContent = 'Ready?';
        startBtn.textContent = 'START';
        if (statsEl) statsEl.classList.add('hidden');
        overlay.classList.remove('hidden');
      });
    }

    // Initial setup
    initGame();
  }
</script>
