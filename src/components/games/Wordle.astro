---
import { VALID_WORDS } from '../../data/words';
---

<div class="w-full h-full flex flex-col items-center justify-start overflow-y-auto bg-surface p-4 relative select-none" id="wordle-container">
  <!-- Restart Button -->
  <button id="wordle-restart-btn" class="absolute top-4 right-4 p-2 bg-surface hover:bg-highlight-med rounded-full border border-highlight-med transition-colors z-20 text-primary" title="Restart Game">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
      <path d="M3 3v5h5"></path>
    </svg>
  </button>

  <!-- Header -->
  <div class="mb-3 flex flex-col items-center justify-center w-full max-w-[350px]">
    <div class="font-pixel text-primary text-2xl mb-1">WORDLE</div>
    <div class="font-pixel text-text-muted text-[10px] text-center mb-2 leading-tight" id="wordle-status">Guess the 5-letter word in 6 tries!</div>
    <div class="flex gap-2 relative z-20">
      <button class="wordle-mode-btn px-2 py-1 text-[10px] font-pixel border border-highlight-high rounded bg-highlight-low text-text hover:bg-highlight-med active" data-mode="daily">DAILY</button>
      <button class="wordle-mode-btn px-2 py-1 text-[10px] font-pixel border border-highlight-high rounded bg-highlight-low text-text hover:bg-highlight-med" data-mode="random">RANDOM</button>
    </div>
  </div>

  <!-- Game Area -->
  <div class="relative w-full max-w-[350px] flex flex-col items-center gap-4">

    <!-- Game Board -->
    <div id="wordle-board" class="flex flex-col gap-2">
      <!-- Generated by JS -->
    </div>

    <!-- Toast Notification -->
    <div id="wordle-toast" class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-overlay border border-highlight-high text-text px-4 py-2 rounded shadow-lg font-pixel text-xs z-30 opacity-0 pointer-events-none transition-opacity whitespace-nowrap">
    </div>

    <!-- Keyboard -->
    <div id="wordle-keyboard" class="w-full flex flex-col gap-1 sm:gap-2 px-1">
      <!-- Generated by JS -->
    </div>

    <!-- Game Over / Start Overlay -->
    <div id="wordle-overlay" class="absolute inset-0 bg-surface/90 backdrop-blur-sm flex flex-col items-center justify-center rounded-lg z-10 transition-opacity duration-300 -m-4">
      <h3 id="wordle-result" class="font-pixel text-primary text-3xl mb-2 text-center">WORDLE</h3>
      <p id="wordle-message" class="font-pixel text-text-muted text-sm mb-6 text-center max-w-[80%]">Guess the 5-letter word in 6 tries!</p>
      <button id="wordle-reset-btn" class="px-6 py-2 bg-primary/10 border-2 border-primary/50 text-primary hover:bg-primary/20 hover:border-primary rounded-lg font-pixel transition-colors">
        PLAY
      </button>
    </div>

  </div>
</div>

<style is:global>
  .wordle-mode-btn.active {
    background-color: var(--color-primary);
    color: var(--color-surface);
    border-color: var(--color-primary);
  }

  /* Board rows */
  .wordle-row {
    display: flex;
    gap: 0.35rem;
    justify-content: center;
  }

  /* Tiles */
  .wordle-tile {
    width: 2.6rem;
    height: 2.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: bold;
    font-family: var(--font-pixel, monospace);
    text-transform: uppercase;
    line-height: 1;
    padding-top: 4px;
    border: 2px solid var(--color-highlight-med);
    border-radius: 0.25rem;
    background-color: var(--color-overlay);
    transition: all 0.2s;
    color: var(--color-text);
  }

  @media (max-width: 400px) {
    .wordle-tile {
      width: 2.25rem;
      height: 2.25rem;
      font-size: 1rem;
    }
  }

  .wordle-tile.filled   { border-color: var(--color-highlight-high); }
  .wordle-tile.correct  { background-color: #31748f; border-color: #31748f; color: white; }
  .wordle-tile.present  { background-color: #f6c177; border-color: #f6c177; color: #191724; }
  .wordle-tile.absent   { background-color: #524f67; border-color: #524f67; color: white; }

  /* Animations */
  .wordle-tile.pop   { animation: wordle-pop   0.1s ease-in-out; }
  .wordle-tile.flip  { animation: wordle-flip  0.5s ease-in-out; }
  .wordle-row.shake  { animation: wordle-shake 0.5s ease-in-out; }

  @keyframes wordle-pop {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.1); }
    100% { transform: scale(1); }
  }
  @keyframes wordle-flip {
    0%   { transform: rotateX(0); }
    50%  { transform: rotateX(90deg); }
    100% { transform: rotateX(0); }
  }
  @keyframes wordle-shake {
    0%, 100%                        { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90%         { transform: translateX(-5px); }
    20%, 40%, 60%, 80%              { transform: translateX(5px); }
  }

  /* Keyboard */
  .wordle-key-row {
    display: flex;
    justify-content: center;
    gap: 0.25rem;
  }

  .wordle-key {
    background-color: var(--color-highlight-med);
    color: var(--color-text);
    border-radius: 0.25rem;
    font-weight: bold;
    font-family: monospace;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    user-select: none;
    transition: all 0.2s;
    height: 2.5rem;
    flex: 1;
    max-width: 2.25rem;
    font-size: 0.875rem;
  }

  @media (max-width: 400px) {
    .wordle-key { height: 2rem; font-size: 0.75rem; }
  }

  .wordle-key:hover { background-color: var(--color-highlight-high); }
  .wordle-key.wide  { max-width: 4rem; font-size: 0.7rem; }

  .wordle-key.correct { background-color: #31748f; color: white; }
  .wordle-key.present { background-color: #f6c177; color: #191724; }
  .wordle-key.absent  { background-color: #524f67; color: white; opacity: 0.5; }
</style>

<script>
  import { VALID_WORDS } from '../../data/words';

  const container   = document.getElementById('wordle-container');

  if (container) {
    const boardEl     = document.getElementById('wordle-board')!;
    const keyboardEl  = document.getElementById('wordle-keyboard')!;
    const overlay     = document.getElementById('wordle-overlay')!;
    const resultEl    = document.getElementById('wordle-result')!;
    const messageEl   = document.getElementById('wordle-message')!;
    const resetBtn    = document.getElementById('wordle-reset-btn') as HTMLButtonElement;
    const restartBtn  = document.getElementById('wordle-restart-btn') as HTMLButtonElement;
    const modeBtns    = document.querySelectorAll<HTMLButtonElement>('.wordle-mode-btn');
    const statusEl    = document.getElementById('wordle-status')!;
    const toastEl     = document.getElementById('wordle-toast')!;

    const ROWS = 6;
    const COLS = 5;
    const dictionary = VALID_WORDS.map(w => w.toUpperCase());

    const KEY_ROWS = [
      ['Q','W','E','R','T','Y','U','I','O','P'],
      ['A','S','D','F','G','H','J','K','L'],
      ['ENTER','Z','X','C','V','B','N','M','BACK']
    ];

    let currentMode       = 'daily';
    let targetWord        = '';
    let guesses: string[] = [];
    let currentGuess      = '';
    let isGameOver        = true;

    // ── Build Board ────────────────────────────────────────────────────────
    function buildBoard() {
      boardEl.innerHTML = '';
      for (let r = 0; r < ROWS; r++) {
        const row = document.createElement('div');
        row.className = 'wordle-row';
        row.id = `wordle-row-${r}`;
        for (let c = 0; c < COLS; c++) {
          const tile = document.createElement('div');
          tile.className = 'wordle-tile';
          tile.id = `wordle-tile-${r}-${c}`;
          row.appendChild(tile);
        }
        boardEl.appendChild(row);
      }
    }

    // ── Build Keyboard ─────────────────────────────────────────────────────
    function buildKeyboard() {
      keyboardEl.innerHTML = '';
      KEY_ROWS.forEach(rowKeys => {
        const row = document.createElement('div');
        row.className = 'wordle-key-row';
        rowKeys.forEach(key => {
          const btn = document.createElement('button');
          btn.className = `wordle-key ${key === 'ENTER' || key === 'BACK' ? 'wide' : ''}`;
          btn.id = `wordle-key-${key}`;
          if (key === 'BACK') {
            btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 4H8l-7 8 7 8h13a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"/><line x1="18" y1="9" x2="12" y2="15"/><line x1="12" y1="9" x2="18" y2="15"/></svg>`;
          } else {
            btn.textContent = key;
          }
          btn.addEventListener('click', () => handleInput(key));
          row.appendChild(btn);
        });
        keyboardEl.appendChild(row);
      });
    }

    // ── Word Selection ─────────────────────────────────────────────────────
    function getDailyWord() {
      const today = new Date();
      const seed  = `${today.getFullYear()}-${today.getMonth()}-${today.getDate()}`;
      let hash = 0;
      for (let i = 0; i < seed.length; i++) hash = Math.imul(31, hash) + seed.charCodeAt(i) | 0;
      return dictionary[Math.abs(hash) % dictionary.length];
    }

    function getRandomWord() {
      return dictionary[Math.floor(Math.random() * dictionary.length)];
    }

    // ── Grid Update ────────────────────────────────────────────────────────
    function updateGrid() {
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          const tile = document.getElementById(`wordle-tile-${r}-${c}`) as HTMLElement;
          if (!tile) continue;

          if (r < guesses.length) {
            // Already submitted — keep coloured state, just ensure text
            tile.textContent = guesses[r][c] || '';
          } else if (r === guesses.length) {
            // Current typing row
            const letter = currentGuess[c] || '';
            if (tile.textContent !== letter) {
              tile.textContent = letter;
              tile.className = `wordle-tile ${letter ? 'filled' : ''}`;
              if (letter) {
                tile.classList.add('pop');
                setTimeout(() => tile.classList.remove('pop'), 100);
              }
            }
          } else {
            tile.textContent = '';
            tile.className = 'wordle-tile';
          }
        }
      }
    }

    // ── Evaluate & Colour Row ──────────────────────────────────────────────
    function evaluateRow(rowIndex: number, animate = true) {
      const guess     = guesses[rowIndex];
      const targetArr = targetWord.split('');
      const guessArr  = guess.split('');
      const statuses  = Array(COLS).fill('absent');

      // Pass 1: greens
      for (let i = 0; i < COLS; i++) {
        if (guessArr[i] === targetArr[i]) {
          statuses[i]  = 'correct';
          targetArr[i] = '#';
        }
      }
      // Pass 2: yellows
      for (let i = 0; i < COLS; i++) {
        if (statuses[i] !== 'correct') {
          const idx = targetArr.indexOf(guessArr[i]);
          if (idx !== -1) {
            statuses[i]    = 'present';
            targetArr[idx] = '#';
          }
        }
      }

      for (let i = 0; i < COLS; i++) {
        const tile = document.getElementById(`wordle-tile-${rowIndex}-${i}`) as HTMLElement;
        const key  = document.getElementById(`wordle-key-${guessArr[i]}`);

        const applyStatus = () => {
          tile.classList.remove('filled');
          tile.classList.add(statuses[i]);
          if (key) {
            if (!key.classList.contains('correct')) {
              if (statuses[i] === 'correct' || !key.classList.contains('present')) {
                key.classList.remove('present', 'absent', 'correct');
                key.classList.add(statuses[i]);
              }
            }
          }
        };

        if (animate) {
          setTimeout(() => {
            tile.classList.add('flip');
            setTimeout(applyStatus, 250);
          }, i * 200);
        } else {
          applyStatus();
        }
      }
    }

    // ── Keyboard colour reset ──────────────────────────────────────────────
    function resetKeyboard() {
      KEY_ROWS.flat().forEach(k => {
        const btn = document.getElementById(`wordle-key-${k}`);
        if (btn) btn.classList.remove('correct', 'present', 'absent');
      });
    }

    // ── Toast ──────────────────────────────────────────────────────────────
    function showToast(msg: string) {
      toastEl.textContent = msg;
      toastEl.classList.remove('opacity-0');
      setTimeout(() => toastEl.classList.add('opacity-0'), 2000);
    }

    // ── Overlay helpers ────────────────────────────────────────────────────
    function showOverlay(title: string, msg: string, btnLabel: string) {
      isGameOver = true;
      resultEl.textContent = title;
      messageEl.innerHTML  = msg;
      resetBtn.textContent = btnLabel;
      overlay.classList.remove('hidden');
    }

    function wordSpan(word: string) {
      return `<span style="color:var(--color-primary);font-size:1.35em;letter-spacing:0.1em;">${word}</span>`;
    }

    function hideOverlay() {
      overlay.classList.add('hidden');
      isGameOver = false;
    }

    // ── Save / Load daily state ────────────────────────────────────────────
    function saveState() {
      if (currentMode === 'daily') {
        localStorage.setItem('wordle-daily-state', JSON.stringify({ guesses, currentGuess, isGameOver }));
        localStorage.setItem('wordle-daily-date', new Date().toDateString());
      }
    }

    // ── Start / Init ───────────────────────────────────────────────────────
    function goToStartScreen() {
      guesses      = [];
      currentGuess = '';
      isGameOver   = true;
      targetWord   = '';
      buildBoard();
      buildKeyboard();
      statusEl.textContent = 'Guess the 5-letter word in 6 tries!';
      showOverlay('WORDLE', 'Guess the 5-letter word in 6 tries!', 'PLAY');
    }

    function startNewGame() {
      guesses      = [];
      currentGuess = '';
      isGameOver   = false;

      if (currentMode === 'daily') {
        targetWord = getDailyWord();
        const savedDate = localStorage.getItem('wordle-daily-date');
        const today     = new Date().toDateString();
        if (savedDate === today) {
          const saved = localStorage.getItem('wordle-daily-state');
          if (saved) {
            const p = JSON.parse(saved);
            guesses      = p.guesses      ?? [];
            currentGuess = p.currentGuess ?? '';
            isGameOver   = p.isGameOver   ?? false;
          }
        } else {
          localStorage.setItem('wordle-daily-date', today);
        }
      } else {
        targetWord = getRandomWord();
      }

      buildBoard();
      resetKeyboard();
      hideOverlay();
      statusEl.textContent = 'Guess the word!';

      // Replay already-submitted guesses
      for (let i = 0; i < guesses.length; i++) {
        // Write letters
        for (let c = 0; c < COLS; c++) {
          const tile = document.getElementById(`wordle-tile-${i}-${c}`) as HTMLElement;
          if (tile) {
            tile.textContent = guesses[i][c];
            tile.classList.add('filled');
          }
        }
        evaluateRow(i, false);
      }
      // Restore current typing row
      updateGrid();

      if (isGameOver) {
        const won = guesses.length > 0 && guesses[guesses.length - 1] === targetWord;
        if (won) showOverlay('Splendid!', `The word was ${wordSpan(targetWord)} 🎉`, 'PLAY AGAIN');
        else     showOverlay('Game Over', `The word was ${wordSpan(targetWord)}.`, 'PLAY AGAIN');
      }
    }

    // ── Input Handler ──────────────────────────────────────────────────────
    function handleInput(key: string) {
      if (isGameOver) return;

      if (key === 'BACK' || key === 'Backspace') {
        if (currentGuess.length > 0) {
          currentGuess = currentGuess.slice(0, -1);
          updateGrid();
        }
        return;
      }

      if (key === 'ENTER' || key === 'Enter') {
        if (currentGuess.length < COLS) {
          showToast('Not enough letters');
          const row = document.getElementById(`wordle-row-${guesses.length}`);
          if (row) { row.classList.add('shake'); setTimeout(() => row.classList.remove('shake'), 500); }
          return;
        }
        if (!dictionary.includes(currentGuess)) {
          showToast('Not in word list');
          const row = document.getElementById(`wordle-row-${guesses.length}`);
          if (row) { row.classList.add('shake'); setTimeout(() => row.classList.remove('shake'), 500); }
          return;
        }

        guesses.push(currentGuess);
        const rowIdx = guesses.length - 1;
        currentGuess = '';
        evaluateRow(rowIdx, true);
        saveState();
        updateGrid();

        const won = guesses[rowIdx] === targetWord;
        if (won) {
          isGameOver = true;
          const labels = ['Genius!', 'Magnificent!', 'Impressive!', 'Splendid!', 'Great!', 'Phew!'];
          statusEl.textContent = 'Game Over';
          setTimeout(() => showOverlay(labels[rowIdx] ?? 'Splendid!', `The word was ${wordSpan(targetWord)} 🎉`, 'PLAY AGAIN'), 1600);
        } else if (guesses.length >= ROWS) {
          isGameOver = true;
          statusEl.textContent = 'Game Over';
          setTimeout(() => showOverlay('Game Over', `The word was ${wordSpan(targetWord)}. Better luck next time!`, 'PLAY AGAIN'), 1600);
        }
        return;
      }

      if (/^[a-zA-Z]$/.test(key) && currentGuess.length < COLS) {
        currentGuess += key.toUpperCase();
        updateGrid();
      }
    }

    // ── Event Listeners ────────────────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      const activeGame = document.querySelector('.game-content:not(.hidden)');
      if (activeGame?.id !== 'game-content-wordle') return;
      if (e.key === 'Backspace' || e.key === 'Enter' || /^[a-zA-Z]$/.test(e.key)) {
        e.preventDefault();
        handleInput(e.key);
      }
    });

    modeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        modeBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentMode = (btn as HTMLElement).dataset.mode ?? 'daily';
        startNewGame();
      });
    });

    resetBtn.addEventListener('click', () => {
      if (resetBtn.textContent?.trim() === 'PLAY') {
        startNewGame();
      } else {
        startNewGame();
      }
    });

    restartBtn.addEventListener('click', goToStartScreen);

    // Boot
    goToStartScreen();
  }
</script>
