---
// AsciiArt.astro
---

<div id="ascii-art" class="tab-panel hidden animate-fade-in">
  <div class="max-w-4xl">
    <h2 class="text-2xl font-bold text-text-primary mb-2">ASCII Art Maker</h2>
    <p class="text-text-muted text-sm mb-6">
      Convert images or text to ASCII art, or generate random cat kaomoji.
    </p>

    <!-- Mode Selector -->
    <div
      class="flex space-x-2 mb-6 p-1 bg-overlay border border-highlight-med rounded-lg w-max"
    >
      <button
        class="ascii-mode-btn active px-4 py-2 rounded-md text-sm font-medium transition-colors bg-primary/20 text-primary border border-primary/30"
        data-mode="image">Image</button
      >
      <button
        class="ascii-mode-btn px-4 py-2 rounded-md text-sm font-medium transition-colors hover:bg-surface-bright text-text-muted border border-transparent"
        data-mode="text">Text</button
      >
      <button
        class="ascii-mode-btn px-4 py-2 rounded-md text-sm font-medium transition-colors hover:bg-surface-bright text-text-muted border border-transparent"
        data-mode="cats">Cats</button
      >
    </div>

    <!-- Image Mode Controls -->
    <div id="ascii-image-controls" class="ascii-controls space-y-4 mb-6">
      <div
        class="border-2 border-dashed border-highlight-med rounded-xl py-10 flex flex-col items-center justify-center gap-5 min-h-[180px]"
      >
        <!-- Beaker SVG -->
        <svg
          class="w-14 h-14"
          viewBox="0 0 64 64"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M22 8 L22 30 L10 52 Q8 56 12 58 L52 58 Q56 56 54 52 L42 30 L42 8"
            stroke="var(--rose,#eb6f92)"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"></path>
          <path
            d="M22 8 L42 8"
            stroke="var(--rose,#eb6f92)"
            stroke-width="3"
            stroke-linecap="round"></path>
          <path
            d="M18 38 Q28 34 46 44"
            stroke="var(--rose,#eb6f92)"
            stroke-width="2"
            stroke-linecap="round"
            fill="none"
            opacity="0.5"></path>
          <path
            d="M14 48 Q28 42 50 52"
            stroke="var(--rose,#eb6f92)"
            stroke-width="2"
            stroke-linecap="round"
            fill="none"
            opacity="0.3"></path>
        </svg>
        <p class="font-pixel text-rose text-sm uppercase tracking-[0.25em]">
          Under Construction
        </p>
        <!-- prettier-ignore -->
        <p class="font-pixel text-text-muted text-[10px] uppercase tracking-widest text-center max-w-xs leading-relaxed">
          Image to ASCII is currently under construction. Probably never gonna release but meh idk.
        </p>
      </div>
    </div>

    <!-- Text Mode Controls -->
    <div id="ascii-text-controls" class="ascii-controls space-y-4 hidden mb-6">
      <div
        class="bg-overlay border-2 border-highlight-med rounded-xl p-6 flex flex-col md:flex-row gap-6 items-start md:items-end"
      >
        <div class="flex-1 w-full">
          <label
            class="block font-pixel text-[10px] text-text-muted uppercase tracking-widest mb-3"
            >Input Text</label
          >
          <input
            type="text"
            id="ascii-text-input"
            placeholder="Type something..."
            class="w-full bg-surface border border-highlight-med rounded-lg px-4 py-2.5 text-sm text-text-primary placeholder-text-muted/50 focus:outline-none focus:border-primary transition-colors"
          />
        </div>
        <div class="w-full md:w-48">
          <label
            class="block font-pixel text-[10px] text-text-muted uppercase tracking-widest mb-3"
            >Font</label
          >
          <select
            id="ascii-font-select"
            class="w-full bg-surface border border-highlight-med rounded-lg px-4 py-2.5 text-sm text-text-primary focus:outline-none focus:border-primary transition-colors appearance-none cursor-pointer"
          >
            <option value="Graffiti">Graffiti</option>
          </select>
        </div>
        <div class="flex items-center pb-1">
          <label class="flex items-center space-x-3 cursor-pointer select-none">
            <div class="relative flex items-center">
              <input
                type="checkbox"
                id="ascii-text-color-mode"
                class="peer sr-only"
              />
              <div
                class="w-10 h-5 bg-surface border border-highlight-med rounded-full peer peer-checked:bg-secondary/20 peer-checked:border-secondary/50 transition-all duration-300"
              >
              </div>
              <div
                class="absolute left-1 top-1 w-3 h-3 bg-text-muted rounded-full peer-checked:bg-secondary peer-checked:translate-x-5 transition-all duration-300"
              >
              </div>
            </div>
            <span
              class="font-pixel text-[10px] text-text-muted uppercase tracking-widest"
              >Random Colors</span
            >
          </label>
        </div>
      </div>
    </div>

    <!-- Cats Mode Controls -->
    <div id="ascii-cats-controls" class="ascii-controls hidden mb-6">
      <div
        class="bg-overlay border-2 border-highlight-med rounded-xl p-6 flex items-center justify-between"
      >
        <p class="text-sm text-text-muted">Summon a random cat emoji!</p>
        <button
          id="ascii-summon-cat"
          class="px-4 py-2 bg-tertiary/10 border border-tertiary/30 hover:bg-tertiary/20 text-tertiary rounded-lg transition-colors flex items-center space-x-2 font-pixel text-[10px] uppercase tracking-widest"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path></svg
          >
          <span>Summon Cat</span>
        </button>
      </div>
    </div>

    <!-- Output Area -->
    <div
      id="ascii-output-container"
      class="bg-surface rounded-xl border border-highlight-med overflow-hidden flex flex-col hidden"
    >
      <div
        class="bg-overlay px-4 py-2.5 border-b border-highlight-med flex justify-between items-center"
      >
        <span
          class="font-pixel text-[9px] text-text-muted uppercase tracking-widest"
          >Output Window</span
        >
        <button
          id="ascii-copy-btn"
          class="text-text-muted hover:text-text-primary transition-colors p-1.5 rounded-md hover:bg-surface-bright border border-transparent hover:border-highlight-med"
          title="Copy to clipboard"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
            ></path></svg
          >
        </button>
      </div>
      <div
        class="p-6 overflow-auto max-h-[600px] flex justify-center bg-black/40 min-h-[300px]"
      >
        <pre
          id="ascii-output"
          class="font-mono text-[8px] leading-[8px] whitespace-pre text-text-primary">
        </pre>
      </div>
    </div>
  </div>
</div>

<script>
  const DENSITY_STRING = "Ñ@#W$9876543210?!abc;:+=-,._ ";

  import { catKaomoji } from "../../data/catKaomoji";

  let currentMode = "image";

  // Elements
  const modeBtns = document.querySelectorAll(".ascii-mode-btn");
  const controls = document.querySelectorAll(".ascii-controls");
  const output = document.getElementById("ascii-output");
  const copyBtn = document.getElementById("ascii-copy-btn");

  // Text elements
  const textInput = document.getElementById("ascii-text-input");
  const textColorCheck = document.getElementById("ascii-text-color-mode");
  const fontSelect = document.getElementById("ascii-font-select");

  let fontsLoaded = false;

  // Load fonts
  const loadFonts = async () => {
    if (fontsLoaded) return;
    try {
      const response = await fetch("/api/fonts");
      if (response.ok) {
        const data = await response.json();
        const fonts = data.fonts || [];
        if (fonts.length > 0) {
          fontSelect.innerHTML = "";
          fonts.forEach((font) => {
            const option = document.createElement("option");
            option.value = font;
            option.textContent = font;
            if (font === "Graffiti") option.selected = true;
            fontSelect.appendChild(option);
          });
          fontsLoaded = true;
        }
      }
    } catch (e) {
      console.error("Error loading fonts:", e);
    }
  };

  // Cat element
  const catBtn = document.getElementById("ascii-summon-cat");

  // Mode switching
  const switchMode = (mode: string) => {
    currentMode = mode;
    localStorage.setItem("ascii-art-mode", mode);

    // Update buttons
    modeBtns.forEach((b) => {
      if (b.dataset.mode === mode) {
        b.classList.remove(
          "hover:bg-surface-bright",
          "text-text-muted",
          "border-transparent",
        );
        b.classList.add("bg-primary/20", "text-primary", "border-primary/30");
      } else {
        b.classList.remove(
          "bg-primary/20",
          "text-primary",
          "border-primary/30",
        );
        b.classList.add(
          "hover:bg-surface-bright",
          "text-text-muted",
          "border-transparent",
        );
      }
    });

    // Update panels
    controls.forEach((c) => c.classList.add("hidden"));
    const activeControl = document.getElementById(`ascii-${mode}-controls`);
    if (activeControl) activeControl.classList.remove("hidden");

    const outputContainer = document.getElementById("ascii-output-container");
    if (outputContainer) {
      if (mode === "image") {
        outputContainer.classList.add("hidden");
      } else {
        outputContainer.classList.remove("hidden");
      }
    }

    // Reset output sizing
    if (output) {
      output.style.fontSize = "8px";
      output.style.lineHeight = "8px";
    }

    if (mode === "image") {
      generateImageAscii();
    } else if (mode === "text") {
      if (!fontsLoaded) {
        loadFonts().then(() => generateTextAscii());
      } else {
        generateTextAscii();
      }
    } else if (mode === "cats") {
      if (output) {
        output.style.fontSize = "24px";
        output.style.lineHeight = "32px";
      }
      summonCat();
    } else {
      if (output) output.innerHTML = "";
    }
  };

  modeBtns.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.dataset.mode) {
        switchMode(target.dataset.mode);
      }
    });
  });

  // Image Mode logic
  const generateImageAscii = () => {
    output.innerHTML = "";
  };

  // Text Mode logic
  let debounceTimeout;

  const generateTextAscii = () => {
    clearTimeout(debounceTimeout);
    debounceTimeout = setTimeout(async () => {
      const text = (textInput as HTMLInputElement).value || "Type Something ";
      const useColor = (textColorCheck as HTMLInputElement).checked;
      const font = (fontSelect as HTMLSelectElement).value || "Graffiti";

      output.innerHTML = "Loading...";
      try {
        const response = await fetch(
          `/api/ascii?text=${encodeURIComponent(text)}&font=${encodeURIComponent(font)}`,
        );
        if (!response.ok) throw new Error("API Error");
        const asciiText = await response.text();

        let finalHtml = "";
        if (useColor) {
          // Colorize character by character
          for (let i = 0; i < asciiText.length; i++) {
            const char = asciiText[i];
            if (char === " " || char === "\\n") {
              finalHtml += char;
            } else {
              const r = Math.floor(Math.random() * 155 + 100);
              const g = Math.floor(Math.random() * 155 + 100);
              const b = Math.floor(Math.random() * 155 + 100);
              // Escape HTML tags to prevent XSS and formatting issues
              const escapedChar =
                char === "<"
                  ? "&lt;"
                  : char === ">"
                    ? "&gt;"
                    : char === "&"
                      ? "&amp;"
                      : char;
              finalHtml += `<span style="color: rgb(${r},${g},${b})">${escapedChar}</span>`;
            }
          }
        } else {
          finalHtml = asciiText
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
        }

        output.innerHTML = finalHtml;
      } catch (err) {
        output.innerHTML = "Error fetching ASCII art.";
        console.error(err);
      }
    }, 300); // 300ms debounce
  };

  textInput?.addEventListener("input", generateTextAscii);
  textColorCheck?.addEventListener("change", generateTextAscii);
  fontSelect?.addEventListener("change", generateTextAscii);

  // Cats Mode logic
  const summonCat = () => {
    const cat = catKaomoji[Math.floor(Math.random() * catKaomoji.length)];
    output.textContent = cat;
  };

  catBtn?.addEventListener("click", summonCat);

  // Copy to clipboard
  copyBtn?.addEventListener("click", () => {
    const textToCopy = output.innerText;
    navigator.clipboard.writeText(textToCopy).then(() => {
      const original = copyBtn.innerHTML;
      copyBtn.innerHTML =
        '<svg class="w-4 h-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
      setTimeout(() => (copyBtn.innerHTML = original), 2000);
    });
  });

  // Initialize mode from localStorage
  const savedMode = localStorage.getItem("ascii-art-mode");
  if (savedMode && savedMode !== "image") {
    // Slight delay so the UI doesn't jump immediately if there is a transition,
    // and to ensure everything is bound
    setTimeout(() => switchMode(savedMode), 0);
  }
</script>
