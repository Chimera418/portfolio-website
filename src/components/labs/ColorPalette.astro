<!-- Color Palette Generator -->
<div id="color-palette" class="tab-panel animate-fade-in hidden">
  <div class="max-w-3xl">
    <h2 class="text-2xl font-bold text-text-primary mb-2">Color Palette Generator</h2>
    <p class="text-text-muted text-sm mb-6">Input a base color to generate harmonic palettes using HSL math.</p>
    
    <div class="bg-overlay border-2 border-highlight-med rounded-xl p-6 flex flex-col md:flex-row gap-8">
      
      <!-- Custom Color Picker -->
      <div class="flex-shrink-0 w-full md:w-64">
        <!-- SV Map -->
        <div id="cp-sat-val" class="w-full h-48 rounded-lg relative cursor-crosshair overflow-hidden mb-5 shadow-inner" style="background-color: hsl(270, 100%, 50%)">
          <div class="absolute inset-0 bg-gradient-to-r from-white to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black to-transparent pointer-events-none"></div>
          <div id="cp-thumb" class="absolute w-5 h-5 border-[3px] border-white rounded-full shadow-[0_0_8px_rgba(0,0,0,0.5)] pointer-events-none -ml-2.5 -mt-2.5 bg-transparent transition-none"></div>
        </div>
        
        <!-- Hue Slider -->
        <div id="cp-hue-track" class="w-full h-4 rounded-full relative cursor-pointer mb-5 shadow-inner" style="background: linear-gradient(to right, #ff0000, #ffff00, #00ff00, #00ffff, #0000ff, #ff00ff, #ff0000)">
          <div id="cp-hue-thumb" class="absolute w-5 h-5 border-[3px] border-white rounded-full shadow-[0_0_8px_rgba(0,0,0,0.5)] pointer-events-none -ml-2.5 -mt-0.5 transition-none" style="top: 0; left: 75%;"></div>
        </div>
        
        <!-- Hex & Preview -->
        <div class="flex gap-3 items-center">
          <div id="cp-preview" class="w-12 h-12 rounded-lg border-2 border-highlight-med shadow-inner" style="background-color: #a855f7"></div>
          <input type="text" id="cp-hex-input" class="bg-surface border border-highlight-med rounded-lg px-4 py-3 text-text-primary font-mono focus:border-primary focus:outline-none flex-1 uppercase" value="#A855F7" maxlength="7" />
        </div>
      </div>

      <!-- Generated Palettes -->
      <div class="flex-1 space-y-6 flex flex-col justify-center">
        <div>
          <h3 class="text-xs font-pixel tracking-widest text-text-muted mb-3 uppercase">Complementary</h3>
          <div id="cp-complementary" class="flex gap-2 h-16"></div>
        </div>
        <div>
          <h3 class="text-xs font-pixel tracking-widest text-text-muted mb-3 uppercase">Analogous</h3>
          <div id="cp-analogous" class="flex gap-2 h-16"></div>
        </div>
        <div>
          <h3 class="text-xs font-pixel tracking-widest text-text-muted mb-3 uppercase">Triadic</h3>
          <div id="cp-triadic" class="flex gap-2 h-16"></div>
        </div>
      </div>
      
    </div>
  </div>
</div>



<script>
  // ── Tool 3: Color Palette Generator ──────────────────────────────────────
  const cpSatVal = document.getElementById('cp-sat-val');
  const cpThumb = document.getElementById('cp-thumb');
  const cpHueTrack = document.getElementById('cp-hue-track');
  const cpHueThumb = document.getElementById('cp-hue-thumb');
  const cpPreview = document.getElementById('cp-preview');
  const cpHex = document.getElementById('cp-hex-input') as HTMLInputElement;
  
  const cpComp = document.getElementById('cp-complementary');
  const cpAnal = document.getElementById('cp-analogous');
  const cpTri = document.getElementById('cp-triadic');

  let curH = 270;
  let curS = 0.65;
  let curV = 0.97;

  // HSV to RGB (returns [0-255, 0-255, 0-255])
  function hsvToRgb(h: number, s: number, v: number) {
    let f = (n: number, k=(n+h/60)%6) => v - v*s*Math.max(Math.min(k, 4-k, 1), 0);
    return [Math.round(f(5)*255), Math.round(f(3)*255), Math.round(f(1)*255)];
  }

  // RGB to HSV (h: 0-360, s: 0-1, v: 0-1)
  function rgbToHsv(r: number, g: number, b: number) {
    r/=255; g/=255; b/=255;
    let max=Math.max(r,g,b), min=Math.min(r,g,b), d=max-min;
    let h = 0, s = max === 0 ? 0 : d/max, v = max;
    if (d!==0) {
      switch(max) {
        case r: h = (g-b)/d + (g<b?6:0); break;
        case g: h = (b-r)/d + 2; break;
        case b: h = (r-g)/d + 4; break;
      }
      h/=6;
    }
    return [h*360, s, v];
  }

  function rgbToHex(r: number, g: number, b: number) {
    return "#" + [r,g,b].map(x=>x.toString(16).padStart(2,'0')).join('');
  }

  function hexToRgb(hex: string) {
    let r=parseInt(hex.slice(1,3),16), g=parseInt(hex.slice(3,5),16), b=parseInt(hex.slice(5,7),16);
    return [r,g,b];
  }

  // Standard HSL math for the palettes
  function hexToHSL(hex: string) {
    let r = parseInt(hex.slice(1,3), 16) / 255;
    let g = parseInt(hex.slice(3,5), 16) / 255;
    let b = parseInt(hex.slice(5,7), 16) / 255;
    let max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h = 0, s = 0, l = (max + min) / 2;
    if (max !== min) {
      let d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch(max) {
        case r: h = (g - b) / d + (g < b ? 6 : 0); break;
        case g: h = (b - r) / d + 2; break;
        case b: h = (r - g) / d + 4; break;
      }
      h /= 6;
    }
    return [h * 360, s * 100, l * 100];
  }

  function hslToHex(h: number, s: number, l: number) {
    l /= 100;
    const a = s * Math.min(l, 1 - l) / 100;
    const f = (n: number) => {
      const k = (n + h / 30) % 12;
      const color = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
      return Math.round(255 * color).toString(16).padStart(2, '0');
    };
    return `#${f(0)}${f(8)}${f(4)}`;
  }

  function renderSwatches(container: HTMLElement | null, hexColors: string[]) {
    if (!container) return;
    container.innerHTML = hexColors.map(c => `
      <div class="color-swatch flex-1 rounded-lg cursor-pointer transition-transform hover:scale-105 active:scale-95 group relative flex items-center justify-center shadow-lg" style="background-color: ${c}" data-hex="${c}">
        <span class="opacity-0 group-hover:opacity-100 transition-opacity bg-surface/80 text-text-primary text-[10px] font-mono px-2 py-1 rounded backdrop-blur-sm pointer-events-none whitespace-nowrap">${c.toUpperCase()}</span>
      </div>
    `).join('');
  }

  // Handle click to copy with visual feedback
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const swatch = target.closest('.color-swatch') as HTMLElement;
    if (swatch) {
      const hex = swatch.dataset.hex;
      if (hex) {
        navigator.clipboard.writeText(hex);
        const span = swatch.querySelector('span');
        if (span) {
          span.textContent = 'COPIED!';
          span.style.color = '#4ade80'; // Tailwind green-400
          setTimeout(() => {
            span.textContent = hex.toUpperCase();
            span.style.color = ''; // reset
          }, 1000);
        }
      }
    }
  });

  function generatePalette(baseHex: string) {
    const [h, s, l] = hexToHSL(baseHex);
    // Complementary
    renderSwatches(cpComp, [baseHex, hslToHex((h + 180) % 360, s, l)]);
    // Analogous
    renderSwatches(cpAnal, [hslToHex((h - 30 + 360) % 360, s, l), baseHex, hslToHex((h + 30) % 360, s, l)]);
    // Triadic
    renderSwatches(cpTri, [baseHex, hslToHex((h + 120) % 360, s, l), hslToHex((h + 240) % 360, s, l)]);
  }

  function updateFromHsv(updateInputs = true) {
    const rgb = hsvToRgb(curH, curS, curV);
    const hex = rgbToHex(rgb[0], rgb[1], rgb[2]);
    
    if (cpPreview) cpPreview.style.backgroundColor = hex;
    if (cpSatVal) cpSatVal.style.backgroundColor = `hsl(${curH}, 100%, 50%)`;
    
    if (cpThumb) {
      cpThumb.style.left = `${curS * 100}%`;
      cpThumb.style.top = `${(1 - curV) * 100}%`;
      cpThumb.style.backgroundColor = hex;
    }
    
    if (cpHueThumb) {
      cpHueThumb.style.left = `${(curH / 360) * 100}%`;
      cpHueThumb.style.backgroundColor = `hsl(${curH}, 100%, 50%)`;
    }
    
    if (updateInputs) {
      if (cpHex) cpHex.value = hex.toUpperCase();
    }
    
    generatePalette(hex);
  }

  // --- Interaction Logic ---
  let isDragging = false;
  
  function updateSv(e: MouseEvent | TouchEvent) {
    if (!cpSatVal) return;
    const rect = cpSatVal.getBoundingClientRect();
    let clientX, clientY;
    if (e.type.startsWith('touch')) {
      clientX = (e as TouchEvent).touches[0].clientX;
      clientY = (e as TouchEvent).touches[0].clientY;
    } else {
      clientX = (e as MouseEvent).clientX;
      clientY = (e as MouseEvent).clientY;
    }
    
    let x = clientX - rect.left;
    let y = clientY - rect.top;
    x = Math.max(0, Math.min(x, rect.width));
    y = Math.max(0, Math.min(y, rect.height));
    
    curS = x / rect.width;
    curV = 1 - (y / rect.height);
    updateFromHsv(true);
  }

  cpSatVal?.addEventListener('mousedown', (e) => {
    isDragging = true;
    updateSv(e);
  });
  cpSatVal?.addEventListener('touchstart', (e) => {
    isDragging = true;
    updateSv(e);
    // Prevent scrolling while dragging inside the picker
    if (e.cancelable) e.preventDefault(); 
  }, { passive: false });

  window.addEventListener('mouseup', () => { isDragging = false; isDraggingHue = false; });
  window.addEventListener('touchend', () => { isDragging = false; isDraggingHue = false; });

  // --- Hue Drag Logic ---
  let isDraggingHue = false;

  function updateHue(e: MouseEvent | TouchEvent) {
    if (!cpHueTrack) return;
    const rect = cpHueTrack.getBoundingClientRect();
    let clientX;
    if (e.type.startsWith('touch')) {
      clientX = (e as TouchEvent).touches[0].clientX;
    } else {
      clientX = (e as MouseEvent).clientX;
    }
    
    let x = clientX - rect.left;
    x = Math.max(0, Math.min(x, rect.width));
    
    curH = (x / rect.width) * 360;
    updateFromHsv(true);
  }

  cpHueTrack?.addEventListener('mousedown', (e) => {
    isDraggingHue = true;
    updateHue(e);
  });
  cpHueTrack?.addEventListener('touchstart', (e) => {
    isDraggingHue = true;
    updateHue(e);
    if (e.cancelable) e.preventDefault();
  }, { passive: false });

  window.addEventListener('mousemove', (e) => { 
    if (isDragging) updateSv(e); 
    if (isDraggingHue) updateHue(e);
  });
  window.addEventListener('touchmove', (e) => { 
    if (isDragging) updateSv(e); 
    if (isDraggingHue) updateHue(e);
  }, { passive: false });

  cpHex?.addEventListener('input', (e) => {
    let val = (e.target as HTMLInputElement).value;
    if (!val.startsWith('#')) val = '#' + val;
    if (/^#[0-9A-Fa-f]{6}$/.test(val)) {
      const rgb = hexToRgb(val);
      const [h, s, v] = rgbToHsv(rgb[0], rgb[1], rgb[2]);
      curH = h; curS = s; curV = v;
      updateFromHsv(false);
    }
  });

  // Init
  const initialRgb = hexToRgb('#a855f7');
  const initialHsv = rgbToHsv(initialRgb[0], initialRgb[1], initialRgb[2]);
  curH = initialHsv[0]; curS = initialHsv[1]; curV = initialHsv[2];
  updateFromHsv(true);
</script>
