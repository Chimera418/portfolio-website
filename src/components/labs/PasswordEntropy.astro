<!-- Password Entropy Checker -->
<div id="password-checker" class="tab-panel animate-fade-in block">
  <div class="max-w-2xl">
    <h2 class="text-2xl font-bold text-text-primary mb-2">Password Entropy Checker</h2>
    <p class="text-text-muted text-sm mb-6">Calculate the true cryptographic strength of your passwords.</p>
    
    <div class="bg-overlay border border-highlight-med rounded-xl p-6">
      <input 
        type="password" 
        id="entropy-input"
        placeholder="Type a password..."
        class="w-full bg-surface border border-highlight-med rounded-lg px-4 py-3 text-text-primary focus:border-primary focus:outline-none transition-colors mb-6 font-mono"
      />

      <div class="space-y-4">
        <div>
          <div class="flex justify-between text-xs font-mono text-text-muted mb-2">
            <span>Entropy</span>
            <span id="entropy-bits">0 bits</span>
          </div>
          <div class="h-2 bg-surface rounded-full overflow-hidden">
            <div id="entropy-bar" class="h-full bg-red-500 w-0 transition-all duration-300"></div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-6">
          <div class="bg-surface rounded-lg p-4 border border-highlight-med">
            <div class="text-[10px] text-text-muted uppercase font-pixel tracking-widest mb-2">Strength</div>
            <div id="entropy-strength" class="font-bold text-lg text-red-500">Very Weak</div>
          </div>
          <div class="bg-surface rounded-lg p-4 border border-highlight-med">
            <div class="text-[10px] text-text-muted uppercase font-pixel tracking-widest mb-2">Crack Time</div>
            <div id="entropy-time" class="font-bold text-lg text-text-primary">Instant</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // ── Tool 1: Password Entropy ─────────────────────────────────────────────
  const entropyInput = document.getElementById('entropy-input');
  const entropyBits = document.getElementById('entropy-bits');
  const entropyBar = document.getElementById('entropy-bar');
  const entropyStrength = document.getElementById('entropy-strength');
  const entropyTime = document.getElementById('entropy-time');

  function calculateEntropy(pwd) {
    if (!pwd) return 0;
    let pool = 0;
    if (/[a-z]/.test(pwd)) pool += 26;
    if (/[A-Z]/.test(pwd)) pool += 26;
    if (/[0-9]/.test(pwd)) pool += 10;
    if (/[^a-zA-Z0-9]/.test(pwd)) pool += 32;
    
    // E = L * log2(R)
    return pwd.length * Math.log2(pool);
  }

  function formatCrackTime(guesses) {
    const guessesPerSecond = 1e10; // Assuming 10 billion guesses/sec
    const seconds = guesses / guessesPerSecond;
    if (seconds < 1) return "Instant";
    if (seconds < 60) return "Seconds";
    if (seconds < 3600) return "Minutes";
    if (seconds < 86400) return "Hours";
    if (seconds < 31536000) return "Days";
    if (seconds < 3153600000) return "Years";
    return "Centuries";
  }

  entropyInput?.addEventListener('input', (e) => {
    const pwd = (e.target as HTMLInputElement).value;
    if (!pwd) {
      if(entropyBits) entropyBits.textContent = '0 bits';
      if(entropyBar) { entropyBar.style.width = '0%'; entropyBar.className = 'h-full transition-all duration-300 bg-red-500'; }
      if(entropyStrength) { entropyStrength.textContent = 'Very Weak'; entropyStrength.style.color = '#ef4444'; }
      if(entropyTime) entropyTime.textContent = 'Instant';
      return;
    }

    const entropy = calculateEntropy(pwd);
    const guesses = Math.pow(2, entropy);
    
    if(entropyBits) entropyBits.textContent = `${Math.round(entropy)} bits`;
    if(entropyTime) entropyTime.textContent = formatCrackTime(guesses);

    let strength = 'Very Weak';
    let color = '#ef4444'; // red
    let pct = Math.min((entropy / 128) * 100, 100);

    if (entropy > 100) {
      strength = 'Unbreakable';
      color = 'var(--secondary)'; // teal
    } else if (entropy > 80) {
      strength = 'Strong';
      color = 'var(--primary)'; // rose/pink
    } else if (entropy > 60) {
      strength = 'Moderate';
      color = 'var(--tertiary)'; // gold
    } else if (entropy > 40) {
      strength = 'Weak';
      color = '#f97316'; // orange
    }

    if(entropyStrength) {
      entropyStrength.textContent = strength;
      entropyStrength.style.color = color;
    }
    
    if(entropyBar) {
      entropyBar.style.width = `${pct}%`;
      entropyBar.style.backgroundColor = color;
    }
  });
</script>
