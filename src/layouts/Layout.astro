---
import "../styles/global.css";
import CommandPalette from "../components/CommandPalette.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html
  lang="en"
  data-theme="mocha"
  data-crt-mode="false"
  data-pixel-mode="false"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Chimera's Realm - Developer Portfolio" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/chimera-favicon.svg" />
    <link rel="icon" type="image/png" href="/chimera-favicon.png" />
    <link rel="icon" type="image/x-icon" href="/chimera-favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google Fonts: Inter and Press Start 2P -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />

    <!-- Initialize Theme Script -->
    <script is:inline>
      const theme = localStorage.getItem("theme") || "mocha";
      const crtMode = localStorage.getItem("crtMode") === "true";
      const pixelMode = localStorage.getItem("pixelMode") === "true";
      const accentColor =
        localStorage.getItem("secondaryAccentColor") || "#cba6f7";

      document.documentElement.setAttribute("data-theme", theme);
      document.documentElement.setAttribute("data-crt-mode", String(crtMode));
      document.documentElement.setAttribute(
        "data-pixel-mode",
        String(pixelMode),
      );

      document.documentElement.style.setProperty("--primary", accentColor);
      document.documentElement.style.setProperty("--secondary", accentColor);
    </script>
  </head>
  <body class="min-h-screen flex flex-col items-center">
    <!-- Navbar will be injected here by pages -->
    <main class="w-full max-w-7xl px-5 sm:px-16 flex-grow py-8 pt-24">
      <slot />
    </main>

    <!-- Webrings -->
    <div
      class="w-full max-w-7xl px-5 sm:px-16 pb-2 flex justify-center font-pixel text-[10px] uppercase tracking-widest text-text-muted"
    >
      <div
        class="bg-overlay border border-highlight-med rounded-xl flex flex-wrap justify-center items-stretch gap-0 min-h-[36px] relative"
      >
        <!-- ● WEBRINGS label -->
        <div class="flex items-center gap-2 px-4 border-r border-highlight-med">
          <span
            class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse shadow-[0_0_8px_var(--primary)] flex-shrink-0"
          ></span>
          <span
            class="text-text-primary font-bold tracking-widest leading-none translate-y-[1px]"
            >WEBRING</span
          >
        </div>

        <!-- Active webring name — links to ring homepage -->
        <a
          id="webring-home"
          href="https://ctp-webr.ing/"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-1.5 px-4 border-r border-highlight-med text-text-primary hover:text-primary transition-colors group/home"
        >
          <svg
            class="w-3 h-3 flex-shrink-0 opacity-50 group-hover/home:opacity-100 transition-opacity"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"
            ></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
          <span id="webring-home-text" class="leading-none translate-y-[1px]"
            >CATPPUCCIN</span
          >
        </a>

        <!-- ← PREV -->
        <a
          id="webring-prev"
          href="https://ctp-webr.ing/chimera/previous"
          aria-label="Previous site"
          class="flex items-center gap-1.5 px-4 border-r border-highlight-med text-text-muted hover:text-primary transition-colors group/prev"
        >
          <svg
            class="w-3 h-3 flex-shrink-0 group-hover/prev:-translate-x-0.5 transition-transform"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          <span class="leading-none translate-y-[1px]">PREV</span>
        </a>

        <!-- 🌐 INDEX -->
        <a
          id="webring-rand"
          href="https://ctp-webr.ing/"
          title="Catppuccin webring index"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-1.5 px-4 border-r border-highlight-med text-primary hover:text-text-primary transition-colors group/rand"
        >
          <svg
            id="webring-icon-home"
            class="w-3.5 h-3.5 flex-shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle><line
              x1="2"
              y1="12"
              x2="22"
              y2="12"></line>
            <path d="M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"></path>
          </svg>
          <span id="webring-rand-text" class="leading-none translate-y-[1px]"
            >INDEX</span
          >
        </a>

        <!-- NEXT → -->
        <a
          id="webring-next"
          href="https://ctp-webr.ing/chimera/next"
          aria-label="Next site"
          class="flex items-center gap-1.5 px-4 text-text-muted hover:text-primary transition-colors group/next"
        >
          <span class="leading-none translate-y-[1px]">NEXT</span>
          <svg
            class="w-3 h-3 flex-shrink-0 group-hover/next:translate-x-0.5 transition-transform"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      </div>
    </div>

    <footer class="w-full max-w-7xl px-5 sm:px-16 py-3 pb-6">
      <div
        class="w-full bg-overlay border border-highlight-med rounded-xl px-5 py-3 grid grid-cols-1 md:grid-cols-3 items-center gap-4 font-pixel text-[10px] uppercase tracking-widest text-text-muted"
      >
        <!-- Left: copyright + status -->
        <div class="flex items-center justify-start gap-4 min-w-0">
          <div class="flex items-center gap-2">
            <span
              class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse shadow-[0_0_8px_var(--primary)]"
            ></span>
            <span
              class="text-text-primary font-bold tracking-widest whitespace-nowrap text-xs translate-y-[1px]"
              >CHIMERA</span
            >
          </div>
          <span class="text-highlight-high hidden sm:block">·</span>
          <span
            class="hidden sm:flex items-center gap-1.5 text-text-muted whitespace-nowrap translate-y-[1px]"
          >
            FULL STACK DEV
          </span>
        </div>

        <!-- Center: command -->
        <div class="hidden md:flex items-center justify-center text-text-muted">
          <span
            class="flex items-center gap-1.5 group cursor-pointer"
            onclick="document.dispatchEvent(new CustomEvent('open-command-palette'))"
          >
            <kbd
              class="bg-surface border border-highlight-med rounded px-1.5 py-0.5 text-[10px] group-hover:border-primary group-hover:text-primary transition-colors font-sans"
              >CTRL</kbd
            >
            <span class="text-[10px] translate-y-[1px]">+</span>
            <kbd
              class="bg-surface border border-highlight-med rounded px-1.5 py-0.5 text-[10px] group-hover:border-primary group-hover:text-primary transition-colors font-sans"
              >K</kbd
            >
            <span
              class="ml-1 group-hover:text-text-primary transition-colors whitespace-nowrap translate-y-[1.5px]"
              >CMD PALETTE</span
            >
          </span>
        </div>

        <!-- Right: time + social icons -->
        <div
          class="flex items-center justify-end gap-4 text-text-muted flex-shrink-0"
        >
          <div
            class="hidden sm:flex items-center gap-1 pr-2 border-r border-highlight-med"
          >
            <svg
              class="w-3 h-3 text-primary"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"
              ></path></svg
            >
            <span
              id="footer-clock"
              class="text-text-primary tracking-wider translate-y-[1.5px]"
              >--:--:--</span
            >
            <span class="text-[10px] ml-0.5 translate-y-[1.5px]">IST</span>
          </div>

          <div class="flex items-center gap-3">
            <a
              href="https://github.com/Chimera418"
              target="_blank"
              rel="noopener"
              class="hover:text-text-primary transition-colors"
              aria-label="GitHub"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"
                ><path
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                ></path></svg
              >
            </a>
            <a
              href="https://www.linkedin.com/in/aneesh-sagar-reddy-222837149"
              target="_blank"
              rel="noopener"
              class="hover:text-text-primary transition-colors"
              aria-label="LinkedIn"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg
              >
            </a>
            <a
              href="https://discord.com/users/736465046317563915"
              target="_blank"
              rel="noopener"
              class="hover:text-text-primary transition-colors"
              aria-label="Discord"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"
                ><path
                  d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
                ></path></svg
              >
            </a>
            <a
              href="mailto:aneeshreddy754@gmail.com"
              class="hover:text-text-primary transition-colors"
              aria-label="Email"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="w-4 h-4"
                ><path
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path></svg
              >
            </a>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        function tick() {
          const now = new Date();
          const ist = new Date(
            now.toLocaleString("en-US", { timeZone: "Asia/Kolkata" }),
          );
          const t = [ist.getHours(), ist.getMinutes(), ist.getSeconds()]
            .map((n) => String(n).padStart(2, "0"))
            .join(":");
          const el = document.getElementById("footer-clock");
          if (el) el.textContent = t;
        }
        tick();
        setInterval(tick, 1000);
      })();
    </script>
    <CommandPalette />
  </body>
</html>
