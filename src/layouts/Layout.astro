---
import "../styles/global.css";
import CommandPalette from "../components/CommandPalette.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import ThemePullCord from "../components/ThemePullCord.tsx";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html
  lang="en"
  data-theme="mocha"
  data-crt-mode="false"
  data-pixel-mode="false"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Chimera's Realm - Developer Portfolio" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/chimera-favicon.svg" />
    <link rel="icon" type="image/png" href="/chimera-favicon.png" />
    <link rel="icon" type="image/x-icon" href="/chimera-favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google Fonts: Inter and Press Start 2P -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />

    <!-- Preload media assets for 404 and music player -->
    <link rel="preload" as="video" type="video/mp4" href="https://occepykq6d5iw5pd.public.blob.vercel-storage.com/Never%20gonna%20Meow%20you%20up.mp4" />
    <link rel="preload" as="audio" type="audio/mpeg" href="https://occepykq6d5iw5pd.public.blob.vercel-storage.com/Voice%20of%20no%20Return%20-%20Normal%20%28NieR_Automata%20Original%20Soundtrack%29%E3%80%90Audio%E3%80%91.mp3" />

    <!-- Initialize Theme Script -->
    <script is:inline>
      let theme = localStorage.getItem("theme");
      if (!theme) {
        theme = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? "latte" : "mocha";
      }
      const crtMode = localStorage.getItem("crtMode") === "true";
      const pixelMode = localStorage.getItem("pixelMode") === "true";
      const accentColor =
        localStorage.getItem("secondaryAccentColor") || "mauve";
      const primaryValue = accentColor.startsWith("#") ? accentColor : `var(--${accentColor})`;

      document.documentElement.setAttribute("data-theme", theme);
      document.documentElement.setAttribute("data-crt-mode", String(crtMode));
      document.documentElement.setAttribute(
        "data-pixel-mode",
        String(pixelMode),
      );

      document.documentElement.style.setProperty("--primary", primaryValue);
      document.documentElement.style.setProperty("--secondary", primaryValue);
    </script>
  </head>
  <body class="relative min-h-screen flex flex-col items-center overflow-x-hidden overflow-hidden">
    <ThemePullCord client:load />

    <!-- Phase 1: Loading Screen -->
    <div id="loader-phase-1" class="fixed inset-0 z-[10001] bg-[#11111b] flex flex-col items-center justify-center transition-opacity duration-700">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#313244]/20 via-[#11111b] to-[#11111b]"></div>
      <div class="font-mono text-center select-none flex flex-col items-center relative z-10">
        <div class="relative mb-12">
          <div class="absolute inset-0 bg-[#cba6f7] opacity-20 blur-2xl rounded-full scale-150"></div>
          <p id="loader-site-name" class="relative text-[16px] sm:text-[20px] tracking-[0.5em] text-[#cdd6f4] opacity-0 transition-opacity duration-1000 uppercase font-bold">chimera's realm</p>
        </div>
        
        <div class="flex flex-col items-center gap-6">
          <div class="flex items-center justify-center gap-2.5">
             <div class="w-1.5 h-1.5 bg-[#cba6f7] rounded-full animate-pulse" style="animation-duration: 1s; animation-delay: 0s;"></div>
             <div class="w-1.5 h-1.5 bg-[#cba6f7] rounded-full animate-pulse" style="animation-duration: 1s; animation-delay: 0.2s;"></div>
             <div class="w-1.5 h-1.5 bg-[#cba6f7] rounded-full animate-pulse" style="animation-duration: 1s; animation-delay: 0.4s;"></div>
          </div>
          <p id="loader-status-text" class="text-[11px] sm:text-[13px] tracking-[0.4em] text-[#6c7086] uppercase">initializing</p>
        </div>
        
        <!-- Progress bar expanding from center -->
        <div class="mt-14 w-64 sm:w-80 h-[2px] bg-[#313244]/50 relative overflow-hidden rounded-full">
          <div id="loader-bar" class="absolute top-0 left-1/2 -translate-x-1/2 h-full bg-gradient-to-r from-transparent via-[#cba6f7] to-transparent w-0 transition-all duration-300 ease-out"></div>
        </div>
      </div>
    </div>

    <!-- Phase 2: Click to Enter Screen -->
    <div id="loader-phase-2" class="fixed inset-0 z-[10000] bg-[#11111b] flex flex-col items-center justify-center transition-opacity duration-700">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#313244]/20 via-[#11111b] to-[#11111b]"></div>
      <div class="font-mono text-center select-none flex flex-col items-center relative z-10">
        <div class="relative mb-12">
          <div class="absolute inset-0 bg-[#cba6f7] opacity-10 blur-2xl rounded-full scale-150"></div>
          <p class="relative text-[16px] sm:text-[20px] tracking-[0.5em] text-[#cdd6f4] uppercase font-bold">chimera's realm</p>
        </div>
        
        <div class="flex items-center justify-center group cursor-pointer transition-transform hover:scale-105 duration-300">
          <p class="text-[13px] sm:text-[15px] tracking-[0.4em] text-[#a6adc8] uppercase transition-colors group-hover:text-[#cdd6f4]">click anywhere to enter</p>
          <span id="enter-cursor" class="inline-block w-[8px] h-[18px] bg-[#cba6f7] ml-4 align-middle shadow-[0_0_12px_#cba6f7]"></span>
        </div>
        
        <div class="mt-16 flex items-center gap-3 opacity-40 hover:opacity-100 transition-opacity duration-500">
          <svg class="w-4 h-4 text-[#cba6f7]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
          <p class="text-[10px] tracking-[0.3em] text-[#a6adc8] uppercase mt-[1px]">Voice of No Return</p>
        </div>
      </div>
    </div>

    <style>
      /* Blinking cursor for phase 2 */
      #enter-cursor {
        animation: blink-cursor 1.2s step-end infinite;
      }
      @keyframes blink-cursor {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }
    </style>

    <script is:inline>
      const phase1 = document.getElementById('loader-phase-1');
      const phase2 = document.getElementById('loader-phase-2');
      const hasLoadedBefore = sessionStorage.getItem('chimera_loaded');

      if (hasLoadedBefore) {
        // Skip Phase 1 and Phase 2 completely if already loaded in this session
        if (phase1) {
          phase1.style.display = 'none';
          phase1.classList.add('opacity-0', 'pointer-events-none');
        }
        if (phase2) {
          phase2.style.display = 'none';
          phase2.classList.add('opacity-0', 'pointer-events-none');
        }
        
        document.body.style.overflow = 'auto';
        
        // Dispatch the event on next tick to ensure components have mounted
        setTimeout(() => {
          document.dispatchEvent(new Event('loader-finished'));
        }, 50);
      } else {
        // Run Phase 1 animations
        const loaderBar = document.getElementById('loader-bar');
        const loaderSiteName = document.getElementById('loader-site-name');

        // Fade in site name
        setTimeout(() => {
          if (loaderSiteName) loaderSiteName.classList.remove('opacity-0');
        }, 150);

        // Animate progress bar (fake progress)
        let progress = 0;
        const barInterval = setInterval(() => {
          if (progress < 80) {
            progress += Math.random() * 12;
            if (progress > 80) progress = 80;
            if (loaderBar) loaderBar.style.width = progress + '%';
          }
        }, 200);

        const videoUrl = "https://occepykq6d5iw5pd.public.blob.vercel-storage.com/Never%20gonna%20Meow%20you%20up.mp4";
        const audioUrl = "https://occepykq6d5iw5pd.public.blob.vercel-storage.com/Voice%20of%20no%20Return%20-%20Normal%20%28NieR_Automata%20Original%20Soundtrack%29%E3%80%90Audio%E3%80%91.mp3";

        const preloadAudio = new Promise(resolve => {
          const audio = new Audio();
          audio.oncanplaythrough = resolve;
          audio.onerror = resolve; // Resolve anyway to not block forever
          audio.src = audioUrl;
          audio.preload = 'auto';
          audio.load();
        });

        const preloadVideo = new Promise(resolve => {
          const video = document.createElement('video');
          video.oncanplaythrough = resolve;
          video.onerror = resolve;
          video.src = videoUrl;
          video.preload = 'auto';
          video.load();
        });

        const preloadMedia = Promise.all([preloadAudio, preloadVideo]);

        // Max 4.5 seconds timeout to give media more time to buffer
        const timeoutPromise = new Promise(resolve => setTimeout(resolve, 4500));

        let transitioned = false;

        const transitionToPhase2 = () => {
          if (transitioned) return;
          transitioned = true;
          clearInterval(barInterval);

          // Complete the bar smoothly
          if (loaderBar) {
            loaderBar.style.width = '100%';
          }

          setTimeout(() => {
            // Fade out phase 1, fade in phase 2
            if (phase1) phase1.classList.add('opacity-0', 'pointer-events-none');
            if (phase2) phase2.classList.remove('opacity-0', 'pointer-events-none');
            sessionStorage.setItem('chimera_loaded', 'true');
          }, 600);
        };

        Promise.all([
          new Promise(resolve => {
            if (document.readyState === 'complete') resolve();
            else window.addEventListener('load', resolve);
          }),
          Promise.race([preloadMedia, timeoutPromise])
        ]).then(() => {
          setTimeout(transitionToPhase2, 400);
        });
      }

      // Handle click to enter — only on phase 2
      if (phase2) {
        phase2.addEventListener('click', () => {
          phase2.classList.add('opacity-0', 'pointer-events-none');
          document.body.classList.remove('overflow-hidden');
          setTimeout(() => {
            if (phase1) phase1.style.display = 'none';
            if (phase2) phase2.style.display = 'none';
          }, 800);
        });
      }
    </script>

    <!-- Navbar will be injected here by pages -->
    <main class="w-full max-w-7xl px-5 sm:px-16 flex-grow py-8 pt-24">
      <slot />
    </main>

    <!-- Webrings -->
    <div
      class="w-full max-w-7xl px-5 sm:px-16 pb-5 flex flex-wrap justify-center items-center gap-4 font-pixel text-[10px] uppercase tracking-widest text-text-muted"
    >
      <div
        data-solid="true"
        class="bg-overlay border border-highlight-med rounded-xl flex flex-wrap justify-center items-stretch gap-0 min-h-[36px] relative"
      >
        <!-- ● WEBRINGS label -->
        <div class="flex items-center gap-2 px-4 border-r border-highlight-med">
          <span
            class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse shadow-[0_0_8px_var(--primary)] flex-shrink-0"
          ></span>
          <span
            class="text-text-primary font-bold tracking-widest leading-none translate-y-[1px]"
            >WEBRINGS</span
          >
        </div>

        <!-- Active webring name — links to ring homepage -->
        <a
          id="webring-home"
          href="https://ctp-webr.ing/"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-1.5 px-4 border-r border-highlight-med text-text-primary hover:text-primary transition-colors group/home"
        >
          <svg
            class="w-3 h-3 flex-shrink-0 opacity-50 group-hover/home:opacity-100 transition-opacity"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"
            ></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
          <span id="webring-home-text" class="leading-none translate-y-[1px]"
            >CATPPUCCIN</span
          >
        </a>

        <!-- Custom chevron dropdown trigger -->
        <div class="relative flex items-center border-r border-highlight-med">
          <button
            id="webring-dropdown-btn"
            onclick="toggleWebringDropdown()"
            class="flex items-center justify-center w-9 h-full text-text-muted hover:text-primary hover:bg-surface/40 transition-colors"
            aria-label="Switch webring"
          >
            <svg
              id="webring-chevron"
              class="w-3 h-3 transition-transform duration-200"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <!-- Custom dropdown panel -->
          <div
            id="webring-dropdown"
            class="hidden absolute top-full left-1/2 -translate-x-1/2 mt-2 z-50 bg-surface border border-highlight-med rounded-xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.4)] min-w-[140px]"
          >
            <button
              onclick="selectWebring('catppuccin')"
              class="webring-opt w-full flex items-center gap-2.5 px-4 py-2.5 text-left text-text-muted hover:text-text-primary hover:bg-overlay transition-colors"
            >
              <span
                id="dot-catppuccin"
                class="w-1 h-1 rounded-full bg-primary opacity-0 transition-opacity flex-shrink-0"
              ></span>
              <span class="leading-none translate-y-[1px]">CATPPUCCIN</span>
            </button>
            <div class="h-px bg-highlight-med mx-3"></div>
            <button
              onclick="selectWebring('threadlocked')"
              class="webring-opt w-full flex items-center gap-2.5 px-4 py-2.5 text-left text-text-muted hover:text-text-primary hover:bg-overlay transition-colors"
            >
              <span
                id="dot-threadlocked"
                class="w-1 h-1 rounded-full bg-primary opacity-0 transition-opacity flex-shrink-0"
              ></span>
              <span class="leading-none translate-y-[1px]">THREADLOCKED</span>
            </button>
          </div>
        </div>

        <!-- ← PREV -->
        <a
          id="webring-prev"
          href="https://ctp-webr.ing/chimera/previous"
          aria-label="Previous site"
          class="flex items-center gap-1.5 px-4 border-r border-highlight-med text-text-muted hover:text-primary transition-colors group/prev"
        >
          <svg
            class="w-3 h-3 flex-shrink-0 group-hover/prev:-translate-x-0.5 transition-transform"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          <span class="leading-none translate-y-[1px]">PREV</span>
        </a>

        <!-- ⚄ RANDOM / 🌐 INDEX -->
        <a
          id="webring-rand"
          href="https://ctp-webr.ing/"
          title="Catppuccin webring index"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-1.5 px-4 border-r border-highlight-med text-primary hover:text-text-primary transition-colors group/rand"
        >
          <svg
            id="webring-icon-dice"
            class="w-3.5 h-3.5 flex-shrink-0 hidden group-hover/rand:rotate-90 transition-transform duration-300"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="2" width="20" height="20" rx="3"></rect>
            <circle cx="8" cy="8" r="1.2" fill="currentColor" stroke="none"
            ></circle>
            <circle cx="16" cy="8" r="1.2" fill="currentColor" stroke="none"
            ></circle>
            <circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none"
            ></circle>
            <circle cx="8" cy="16" r="1.2" fill="currentColor" stroke="none"
            ></circle>
            <circle cx="16" cy="16" r="1.2" fill="currentColor" stroke="none"
            ></circle>
          </svg>
          <svg
            id="webring-icon-home"
            class="w-3.5 h-3.5 flex-shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle><line
              x1="2"
              y1="12"
              x2="22"
              y2="12"></line>
            <path d="M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"></path>
          </svg>
          <span id="webring-rand-text" class="leading-none translate-y-[1px]"
            >INDEX</span
          >
        </a>

        <!-- NEXT → -->
        <a
          id="webring-next"
          href="https://ctp-webr.ing/chimera/next"
          aria-label="Next site"
          class="flex items-center gap-1.5 px-4 text-text-muted hover:text-primary transition-colors group/next"
        >
          <span class="leading-none translate-y-[1px]">NEXT</span>
          <svg
            class="w-3 h-3 flex-shrink-0 group-hover/next:translate-x-0.5 transition-transform"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      </div>

    </div>

    <script is:inline>
      var _webringVal = "catppuccin";

      function toggleWebringDropdown() {
        var dd = document.getElementById("webring-dropdown");
        var chv = document.getElementById("webring-chevron");
        var open = !dd.classList.contains("hidden");
        if (open) {
          dd.classList.add("hidden");
          chv.style.transform = "";
        } else {
          dd.classList.remove("hidden");
          chv.style.transform = "rotate(180deg)";
        }
      }

      function selectWebring(val) {
        _webringVal = val;
        var dd = document.getElementById("webring-dropdown");
        if (dd) dd.classList.add("hidden");
        var chv = document.getElementById("webring-chevron");
        if (chv) chv.style.transform = "";
        applyWebring(val);
      }

      function applyWebring(val) {
        var prev = document.getElementById("webring-prev");
        var next = document.getElementById("webring-next");
        var rand = document.getElementById("webring-rand");
        var randText = document.getElementById("webring-rand-text");
        var iconDice = document.getElementById("webring-icon-dice");
        var iconHome = document.getElementById("webring-icon-home");
        var homeLink = document.getElementById("webring-home");
        var homeTxt = document.getElementById("webring-home-text");
        var dotCat = document.getElementById("dot-catppuccin");
        var dotThr = document.getElementById("dot-threadlocked");

        if (dotCat) dotCat.classList.replace("opacity-100", "opacity-0");
        if (dotThr) dotThr.classList.replace("opacity-100", "opacity-0");

        if (val === "threadlocked") {
          prev.href = "https://ring.seggs.lol/redirect?from=chimera&dir=prev";
          next.href = "https://ring.seggs.lol/redirect?from=chimera&dir=next";
          rand.href = "https://ring.seggs.lol/random";
          rand.title = "Random site on Threadlocked webring";
          randText.textContent = "RANDOM";
          homeLink.href = "https://ring.seggs.lol";
          homeTxt.textContent = "THREADLOCKED";
          iconDice.classList.remove("hidden");
          iconHome.classList.add("hidden");
          if (dotThr) dotThr.classList.replace("opacity-0", "opacity-100");
        } else {
          prev.href = "https://ctp-webr.ing/chimera/previous";
          next.href = "https://ctp-webr.ing/chimera/next";
          rand.href = "https://ctp-webr.ing/";
          rand.title = "Catppuccin webring index";
          randText.textContent = "INDEX";
          homeLink.href = "https://ctp-webr.ing/";
          homeTxt.textContent = "CATPPUCCIN";
          iconDice.classList.add("hidden");
          iconHome.classList.remove("hidden");
          if (dotCat) dotCat.classList.replace("opacity-0", "opacity-100");
        }
      }

      document.addEventListener("click", function (e) {
        var btn = document.getElementById("webring-dropdown-btn");
        var dd = document.getElementById("webring-dropdown");
        if (dd && !dd.contains(e.target) && btn && !btn.contains(e.target)) {
          dd.classList.add("hidden");
          var chv = document.getElementById("webring-chevron");
          if (chv) chv.style.transform = "";
        }
      });

      // Initialize active state
      if (typeof document !== "undefined") {
        setTimeout(function () {
          applyWebring(_webringVal);
        }, 0);
      }
    </script>

    <footer class="w-full max-w-7xl px-5 sm:px-16 py-3 pb-8 flex items-end gap-6">

      <div
        data-solid="true"
        class="w-full bg-overlay border border-highlight-med rounded-xl px-5 py-3 grid grid-cols-1 md:grid-cols-3 items-center gap-4 font-pixel text-[10px] uppercase tracking-widest text-text-muted"
      >
        <!-- Left: copyright + status -->
        <div class="flex items-center justify-start gap-4 min-w-0">
          <div class="flex items-center gap-2">
            <span
              class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse shadow-[0_0_8px_var(--primary)]"
            ></span>
            <span
              class="text-text-primary font-bold tracking-widest whitespace-nowrap text-xs translate-y-[1px]"
              >CHIMERA</span
            >
          </div>
          <span class="text-highlight-high hidden sm:block">·</span>
          <span
            class="hidden sm:flex items-center gap-1.5 text-text-muted whitespace-nowrap translate-y-[1px]"
          >
            FULL STACK DEV
          </span>
        </div>

        <!-- Center: command -->
        <div class="hidden md:flex items-center justify-center text-text-muted">
          <span
            class="flex items-center gap-1.5 group cursor-pointer"
            onclick="document.dispatchEvent(new CustomEvent('open-command-palette'))"
          >
            <kbd
              class="bg-surface border border-highlight-med rounded px-1.5 py-0.5 text-[10px] group-hover:border-primary group-hover:text-primary transition-colors font-sans"
              >CTRL</kbd
            >
            <span class="text-[10px] translate-y-[1px]">+</span>
            <kbd
              class="bg-surface border border-highlight-med rounded px-1.5 py-0.5 text-[10px] group-hover:border-primary group-hover:text-primary transition-colors font-sans"
              >K</kbd
            >
            <span
              class="ml-1 group-hover:text-text-primary transition-colors whitespace-nowrap translate-y-[1.5px]"
              >CMD PALETTE</span
            >
          </span>
        </div>

        <!-- Right: time + social icons -->
        <div
          class="flex items-center justify-end gap-4 text-text-muted flex-shrink-0"
        >
          <div
            class="hidden sm:flex items-center gap-1 pr-2 border-r border-highlight-med"
          >
            <svg
              class="w-3 h-3 text-primary"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"
              ></path></svg
            >
            <span
              id="footer-clock"
              class="text-text-primary tracking-wider translate-y-[1.5px]"
              >--:--:--</span
            >
            <span class="text-[10px] ml-0.5 translate-y-[1.5px]">IST</span>
          </div>

