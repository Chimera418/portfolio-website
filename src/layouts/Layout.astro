    <script is:inline>
      // Back to top logic
      (function() {
        var isShow = false, lock = false;
        var btn = document.querySelector('.back-to-top');
        if (!btn) return;

        var triggerPopIn = function() {
          if (lock || isShow) return;
          btn.classList.add('load');
          isShow = true;

          // Disappear automatically after 10 seconds if not clicked
          setTimeout(function() {
            if (isShow && !lock) {
              btn.classList.remove('load');
              isShow = false;
            }
          }, 10000);
        };

        var scheduleNextPop = function() {
          // Random time between 45 seconds and 90 seconds
          var nextTime = Math.floor(Math.random() * (90000 - 45000 + 1)) + 45000;
          setTimeout(function() {
            triggerPopIn();
            scheduleNextPop();
          }, nextTime);
        };

        var handleClick = function() {
          lock = true;
          btn.classList.add('ani-leave');
          window.scrollTo({ top: 0, behavior: 'smooth' });

          setTimeout(function() {
            btn.classList.remove('ani-leave');
            btn.classList.add('leaved');
          }, 390);

          setTimeout(function() { btn.classList.add('ending'); }, 120);
          setTimeout(function() { btn.classList.remove('load'); }, 1500);

          setTimeout(function() {
            lock = false;
            isShow = false;
            btn.classList.remove('leaved', 'ending');
          }, 2000);
        };

        btn.addEventListener('click', handleClick);

        // Pop up shortly after the page loads, then start the random schedule
        setTimeout(function() {
          triggerPopIn();
          scheduleNextPop();
        }, 5000);
      })();
    </script>
