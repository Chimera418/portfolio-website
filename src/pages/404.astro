---
import "../styles/global.css";
import CommandPalette from "../components/CommandPalette.astro";
import CaptchaModal from "../components/CaptchaModal.astro";
---

<!doctype html>
<html lang="en" data-theme="mocha">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found</title>
    <link rel="icon" type="image/svg+xml" href="/chimera-favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="w-screen h-screen overflow-hidden bg-black m-0 p-0">
    <CommandPalette />

    <!-- Background Video -->
    <div
      class="fixed inset-0 w-full h-full z-0 overflow-hidden bg-black flex items-center justify-center pointer-events-none"
    >
      <video
        id="bg-video"
        class="min-w-full min-h-full object-cover opacity-80"
        src="/video/never-gonna-meow-you-up.mp4"
        autoplay
        loop
        playsinline></video>
    </div>

    <!-- UI Overlay -->
    <main
      id="main-content"
      class="relative z-10 w-full h-full flex flex-col items-center justify-center pointer-events-none p-4 transition-opacity duration-500"
    >
      <!-- 404 Glitch Text -->
      <div class="relative inline-block mb-8">
        <h1
          class="text-7xl md:text-9xl font-pixel text-primary drop-shadow-[6px_6px_0_rgba(0,0,0,0.8)] select-none"
        >
          404
        </h1>
      </div>

      <!-- Explainer Text Box -->
      <div class="pointer-events-auto max-w-lg w-full mb-10 rounded-xl overflow-hidden border-2 border-highlight-med bg-surface/90 backdrop-blur-xl shadow-[8px_8px_0_rgba(0,0,0,0.5)] transition-all hover:shadow-[10px_10px_0_var(--primary)] hover:border-primary/50 duration-500">
        <!-- Window Titlebar -->
        <div class="bg-surface-dim border-b-2 border-highlight-med px-4 py-2 flex items-center gap-2">
          <div class="w-3 h-3 rounded-full bg-red"></div>
          <div class="w-3 h-3 rounded-full bg-[#f9e2af]"></div>
          <div class="w-3 h-3 rounded-full bg-green"></div>
          <span class="ml-2 font-pixel text-[10px] text-text-muted uppercase tracking-wider">ERROR_LOG.TXT</span>
        </div>
        
        <!-- Window Content -->
        <div class="text-text-primary/90 font-mono text-center p-6 leading-relaxed flex flex-col items-center gap-4">
          <p>
            <span class="text-primary font-bold">Congratulations!!</span> You've been
            <span class="text-primary font-bold">meow-rolled</span>.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span>Use</span>
            <button
              onclick="document.dispatchEvent(new CustomEvent('open-command-palette'))"
              class="pointer-events-auto inline-flex items-center justify-center px-3 py-1.5 bg-surface-dim hover:bg-surface rounded border-2 border-primary/40 hover:border-primary transition-all cursor-pointer shadow-[3px_3px_0_var(--primary)] active:translate-y-0.5 active:shadow-[1px_1px_0_var(--primary)]"
            >
              <kbd class="font-sans text-xs text-primary font-bold tracking-wider">CTRL + K</kbd>
            </button>
            <span>to jump to other webpages,</span>
          </div>
          <p>or click the button below to return to the home page.</p>
        </div>
      </div>

      <!-- Actions Container -->
      <div id="actions-container" class="relative flex flex-col items-center justify-center min-h-[80px]">
        <!-- Return Button -->
        <button
          type="button"
          id="btn-return-home"
          onclick="document.getElementById('btn-return-home').classList.add('opacity-0', 'pointer-events-none'); document.getElementById('captcha-widget').classList.remove('opacity-0', 'pointer-events-none'); document.getElementById('captcha-widget').classList.add('opacity-100', 'pointer-events-auto');"
          class="pointer-events-auto font-pixel text-sm md:text-base uppercase tracking-widest text-surface bg-primary border-2 border-primary hover:bg-surface hover:text-primary px-8 py-4 rounded-xl transition-all hover:-translate-y-1 active:translate-y-0 shadow-[6px_6px_0_rgba(0,0,0,0.8)] hover:shadow-[8px_8px_0_var(--primary)] cursor-pointer absolute z-10"
        >
          Return to Home Page
        </button>

        <!-- Captcha Widget -->
        <button
          type="button"
          id="captcha-widget"
          class="pointer-events-none opacity-0 flex items-center gap-4 bg-surface p-4 rounded-xl border-2 border-highlight-med hover:border-primary transition-all duration-300 shadow-[6px_6px_0_rgba(0,0,0,0.5)] hover:shadow-[8px_8px_0_var(--primary)] active:translate-y-1 active:shadow-none cursor-pointer w-[280px]"
          onclick="document.getElementById('bg-video')?.pause(); document.dispatchEvent(new CustomEvent('open-captcha-modal'));"
        >
          <div class="w-7 h-7 border-2 border-text-muted rounded-md bg-surface flex-shrink-0 flex items-center justify-center transition-colors">
            <!-- Empty box to simulate a checkbox -->
          </div>
          <span class="text-text-primary font-mono text-sm tracking-wide">I am human</span>
          <div class="ml-auto flex-shrink-0 opacity-80">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8 text-primary">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
        </button>
      </div>
    </main>

    <CaptchaModal />

    <!-- Unmute Button -->
    <button
      type="button"
      id="unmute-btn"
      class="pointer-events-auto fixed top-8 right-8 z-[250] bg-surface/90 backdrop-blur-md border-2 border-highlight-med hover:border-primary text-text-primary hover:text-primary px-5 py-4 rounded-xl font-pixel text-xs tracking-widest shadow-xl transition-all hover:-translate-y-1 active:translate-y-0 flex items-center justify-center gap-2 group"
    >
      <svg
        id="icon-muted"
        class="w-4 h-4 group-hover:text-primary transition-colors hidden translate-y-[-1px]"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line
          x1="23"
          y1="9"
          x2="17"
          y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg
      >
      <svg
        id="icon-unmuted"
        class="w-4 h-4 text-primary translate-y-[-1px]"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path
          d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path
          d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg
      >
      <span id="unmute-text">MUTE</span>
    </button>

    <!-- Initialize Theme Script -->
    <script is:inline>
      function applyTheme() {
        let theme = localStorage.getItem("theme");
        if (!theme) {
          theme = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? "latte" : "mocha";
        }
        const crtMode = localStorage.getItem("crtMode") === "true";
        const pixelMode = localStorage.getItem("pixelMode") === "true";
        const accentColor = localStorage.getItem("secondaryAccentColor") || "mauve";
        const primaryValue = accentColor.startsWith("#") ? accentColor : `var(--${accentColor})`;

        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.setAttribute("data-crt-mode", String(crtMode));
        document.documentElement.setAttribute("data-pixel-mode", String(pixelMode));

        document.documentElement.style.setProperty("--primary", primaryValue);
        document.documentElement.style.setProperty("--secondary", primaryValue);
      }

      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <script>
      // Unmute logic
      const unmuteBtn = document.getElementById("unmute-btn");
      const unmuteText = document.getElementById("unmute-text");
      const iconMuted = document.getElementById("icon-muted");
      const iconUnmuted = document.getElementById("icon-unmuted");
      const bgVideo = document.querySelector("video");

      if (unmuteBtn && bgVideo) {
        bgVideo.volume = 0.5;
        bgVideo.muted = false;

        // Attempt to play unmuted. If the browser blocks it due to autoplay policies,
        // we will wait for the first click on the document to start playing unmuted.
        const playPromise = bgVideo.play();
        if (playPromise !== undefined) {
          playPromise.catch(() => {
            // Browser blocked unmuted autoplay.
            // Play it muted for now so the background is moving.
            bgVideo.muted = true;
            unmuteText.textContent = "UNMUTE";
            iconMuted.classList.remove("hidden");
            iconUnmuted.classList.add("hidden");
            bgVideo.play();

            // Setup a one-time click listener on the whole document to unmute
            const unlockAudio = () => {
              bgVideo.muted = false;
              unmuteText.textContent = "MUTE";
              iconMuted.classList.add("hidden");
              iconUnmuted.classList.remove("hidden");
              document.removeEventListener("click", unlockAudio);
              document.removeEventListener("keydown", unlockAudio);
            };
            document.addEventListener("click", unlockAudio);
            document.addEventListener("keydown", unlockAudio);
          });
        }

        unmuteBtn.addEventListener("click", (e) => {
          e.stopPropagation(); // prevent triggering the document listener immediately if clicked
          if (bgVideo.muted) {
            bgVideo.muted = false;
            bgVideo.volume = 0.5;
            unmuteText.textContent = "MUTE";
            iconMuted.classList.add("hidden");
            iconUnmuted.classList.remove("hidden");
          } else {
            bgVideo.muted = true;
            unmuteText.textContent = "UNMUTE";
            iconMuted.classList.remove("hidden");
            iconUnmuted.classList.add("hidden");
          }
        });
      }
    </script>
  </body>
</html>
