---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("devlog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
if (!post) {
  return Astro.redirect('/404');
}
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | Chimera`}>
  <Navbar />

  <article class="mt-8 max-w-3xl mx-auto animate-fade-in pb-16">
    <header class="mb-12 text-center">
      <div class="mb-6">
        <a
          href="/devlog"
          class="text-primary hover:text-text-primary transition-colors font-pixel text-[10px] tracking-widest uppercase flex items-center justify-center gap-2"
        >
          <span class="-translate-y-[3px]">&larr;</span> Back to Log
        </a>
      </div>
      <h1
        class="text-3xl md:text-4xl font-bold text-text-primary mb-6 leading-tight"
      >
        {post.data.title}
      </h1>
      <div
        class="flex justify-center items-center gap-4 text-text-muted font-pixel text-[10px] uppercase tracking-widest"
      >
        <time datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
      </div>
    </header>

    <div class="markdown-body text-lg leading-relaxed text-text-primary">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Custom Markdown Styling for Rosé Pine */
  .markdown-body h1,
  .markdown-body h2,
  .markdown-body h3,
  .markdown-body h4 {
    color: var(--text-primary);
    font-weight: 700;
    margin-top: 2em;
    margin-bottom: 0.75em;
    line-height: 1.3;
  }
  .markdown-body h1 {
    font-size: 2.25rem;
  }
  .markdown-body h2 {
    font-size: 1.875rem;
    border-bottom: 1px solid var(--highlight-med);
    padding-bottom: 0.3em;
  }
  .markdown-body h3 {
    font-size: 1.5rem;
  }

  .markdown-body p {
    margin-bottom: 1.5em;
    color: var(--text-muted);
  }

  .markdown-body a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s;
  }
  .markdown-body a:hover {
    color: var(--text-primary);
  }

  .markdown-body strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .markdown-body blockquote {
    border-left: 4px solid var(--primary);
    padding: 0.5em 1em;
    margin: 1.5em 0;
    background: var(--surface-bright);
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .markdown-body ul,
  .markdown-body ol {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
    color: var(--text-muted);
  }
  .markdown-body ul {
    list-style-type: disc;
  }
  .markdown-body ol {
    list-style-type: decimal;
  }
  .markdown-body li {
    margin-bottom: 0.5em;
  }

  .markdown-body code {
    background: var(--surface-bright);
    color: var(--secondary);
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: var(--font-pixel);
  }

  .markdown-body pre {
    background: var(--overlay) !important;
    border: 1px solid var(--highlight-med);
    padding: 1.25em;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5em 0;
  }
  .markdown-body pre code {
    background: transparent;
    color: inherit;
    padding: 0;
    font-family: "Consolas", "Monaco", monospace; /* fallback for readability */
    font-size: 0.9em;
  }

  .markdown-body hr {
    border: 0;
    border-top: 1px solid var(--highlight-med);
    margin: 2.5em 0;
  }
</style>
