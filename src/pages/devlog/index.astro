---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

const allPosts = await getCollection('devlog', ({ data }) => {
  return data.draft !== true;
});

// Sort by date descending
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Devlog | Chimera">
  <Navbar />
  
  <div class="mt-8 max-w-4xl mx-auto space-y-12 animate-fade-in">
    <!-- Header -->
    <section class="text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
        Developer <span class="text-tertiary font-pixel text-2xl md:text-3xl align-middle">Log</span>
      </h1>
      <p class="text-lg text-text-muted">
        Writeups, technical notes, and build logs.
      </p>
    </section>

    <!-- Post List -->
    <section class="space-y-6">
      {allPosts.map((post) => (
        <a href={`/devlog/${post.id}`} class="block bg-surface-dim border border-highlight-med rounded-xl p-6 hover:border-tertiary transition-colors group">
          <div class="flex flex-col md:flex-row justify-between md:items-center mb-2 gap-2">
            <h2 class="text-2xl font-bold text-text-primary group-hover:text-tertiary transition-colors">{post.data.title}</h2>
            <span class="font-pixel text-[10px] text-text-muted whitespace-nowrap">
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              })}
            </span>
          </div>
          <p class="text-text-muted mb-4">{post.data.description}</p>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map(tag => (
              <span class="px-2 py-1 bg-surface-bright border border-highlight-med text-text-muted text-[10px] uppercase tracking-wider font-pixel rounded">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </section>
  </div>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
