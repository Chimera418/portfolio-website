  { id: 'tetris',        title: 'Tetris',          desc: 'Stack blocks, clear lines',     genre: 'Puzzle',         difficulty: 'Hard'   },
  { id: '2048',          title: '2048',            desc: 'Slide & merge to win',          genre: 'Strategy',       difficulty: 'Medium' },
  { id: 'flappy-bird',   title: 'Flappy Bird',     desc: 'Navigate the pipes',            genre: 'Reflex',         difficulty: 'Hard'   },
  { id: 'memory-match',  title: 'Memory Match',    desc: 'Find every matching pair',      genre: 'Memory',         difficulty: 'Easy'   },
  { id: 'tic-tac-toe',   title: 'Tic Tac Toe',    desc: 'Play vs friend or AI',          genre: 'Strategy',       difficulty: 'Easy'   },
  { id: 'dont-wordle',   title: "Don't Wordle",    desc: "Survive without guessing it",   genre: 'Word Game',      difficulty: 'Hard'   },
  { id: 'color-guesser', title: 'Color Guesser',   desc: 'Match the RGB swatch',          genre: 'Visual Quiz',    difficulty: 'Medium' },
  { id: 'wordle',        title: 'Wordle',          desc: 'Guess the 5-letter word',       genre: 'Word Game',      difficulty: 'Medium' },
  { id: 'connect-4',     title: 'Connect 4',       desc: 'Drop discs, connect four',      genre: 'Strategy',       difficulty: 'Medium' },
];
---

<Layout title="Games | Chimera's Realm">
  <Navbar />

  <!-- Page content sits inside Layout's <main> which already has pt-24 px-5 sm:px-16 -->
  <div class="mt-8 max-w-6xl mx-auto space-y-10 animate-fade-in">

    <!-- Header -->
    <section>
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-3">
        Chimera's <span class="text-primary font-pixel text-2xl md:text-3xl align-middle">Arcade</span>
      </h1>
      <p class="text-text-muted text-base max-w-lg">
        Nine browser games. No downloads, no nonsense — just click and play.
      </p>
    </section>

    <!-- Game Grid — 3 cols on desktop, 2 tablet, 1 mobile -->
    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="arcade-grid">
      {games.map((game) => (
        <div
          data-game={game.id}
          class="game-card group cursor-pointer bg-surface-dim border border-highlight-med rounded-xl overflow-hidden hover:border-primary transition-colors duration-200"
        >
          <div class="p-5 flex flex-col gap-4">

            <!-- Icon row + genre badge -->
            <div class="flex items-start justify-between gap-3">
              <span class="text-primary leading-none select-none group-hover:scale-110 transition-transform duration-200 inline-block shrink-0" set:html={gameIcons[game.id]} />
              <span class="shrink-0 bg-overlay text-text-muted border border-highlight-med rounded px-2 py-1 text-[10px] font-mono uppercase tracking-wider whitespace-nowrap">
                {game.genre}
              </span>
            </div>

            <!-- Title + description -->
            <div>
              <h3 class="font-bold text-text-primary text-base mb-1 group-hover:text-primary transition-colors duration-200">
                {game.title}
              </h3>
              <p class="text-text-muted text-sm leading-relaxed">{game.desc}</p>
            </div>

            <!-- Footer: difficulty + play hint -->
            <div class="flex items-center justify-between pt-3 border-t border-highlight-med">
              <div class="flex items-center gap-2">
                <div class={`w-1.5 h-1.5 rounded-full shrink-0 ${
                  game.difficulty === 'Easy'   ? 'bg-green'  :
                  game.difficulty === 'Medium' ? 'bg-yellow' :
                                                 'bg-red'
                }`}></div>
                <span class="text-text-muted text-xs font-mono uppercase tracking-wider">{game.difficulty}</span>
              </div>
              <span class="text-primary text-xs font-mono uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse shrink-0"></span>
                Play now
              </span>
            </div>

          </div>
        </div>
      ))}
    </section>

  </div>

  <!-- ── Fullscreen Game Overlay — rendered outside <main>, truly fullscreen ── -->
  <div id="game-overlay" class="fixed inset-0 z-[9999] bg-surface-dim flex-col hidden">

    <!-- Inner wrapper: fades in after the expand completes -->
    <div class="overlay-inner flex flex-col w-full h-full">

      <!-- Top bar -->
      <div class="w-full h-12 border-b border-highlight-med bg-overlay flex items-center justify-between px-5 flex-shrink-0">
        <div class="flex items-center gap-3">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-red/80"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-yellow/80"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-green/80"></div>
          </div>
          <span class="font-mono text-xs text-text-muted">chimera@arcade</span>
          <span class="text-highlight-med">›</span>
          <span id="game-overlay-title" class="font-mono text-xs text-primary uppercase tracking-wider">—</span>
        </div>
        <button
          id="close-game-btn"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-highlight-med text-text-muted font-mono text-xs uppercase tracking-wider hover:border-red/60 hover:text-red transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          ESC to quit
        </button>
      </div>

      <!-- Game viewport -->
      <div class="flex-grow relative overflow-hidden flex items-center justify-center p-4 md:p-8 bg-surface-dim">
        <div id="game-content-chrome-dino"   class="game-content hidden w-full h-full max-w-5xl  max-h-[560px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><ChromeDino /></div>
        <div id="game-content-snake"         class="game-content hidden w-full h-full max-w-3xl  max-h-[580px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><Snake /></div>
        <div id="game-content-tetris"        class="game-content hidden w-full h-full max-w-3xl  max-h-[760px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><Tetris /></div>
        <div id="game-content-2048"          class="game-content hidden w-full h-full max-w-lg   max-h-[580px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><Game2048 /></div>
        <div id="game-content-flappy-bird"   class="game-content hidden w-full h-full max-w-md   max-h-[580px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><FlappyBird /></div>
        <div id="game-content-memory-match"  class="game-content hidden w-full h-full max-w-4xl  max-h-[680px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><MemoryMatch /></div>
        <div id="game-content-tic-tac-toe"   class="game-content hidden w-full h-full max-w-lg   max-h-[580px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><TicTacToe /></div>
        <div id="game-content-dont-wordle"   class="game-content hidden w-full h-full max-w-4xl  max-h-[820px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><DontWordle /></div>
        <div id="game-content-color-guesser" class="game-content hidden w-full h-full max-w-3xl  max-h-[560px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl"><ColorGuesser /></div>
        <div id="game-content-wordle"        class="game-content hidden w-full h-full max-w-md   max-h-[700px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl bg-surface-dim"><Wordle /></div>
        <div id="game-content-connect-4"     class="game-content hidden w-full h-full max-w-2xl  max-h-[700px] border border-highlight-med rounded-xl overflow-hidden shadow-2xl bg-surface-dim"><Connect4 /></div>
      </div>

    </div>
  </div>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out both;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .game-card {
    animation: cardIn 0.35s ease-out both;
  }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .game-card:nth-child(1) { animation-delay: 0.04s; }
  .game-card:nth-child(2) { animation-delay: 0.08s; }
  .game-card:nth-child(3) { animation-delay: 0.12s; }
  .game-card:nth-child(4) { animation-delay: 0.16s; }
  .game-card:nth-child(5) { animation-delay: 0.20s; }
  .game-card:nth-child(6) { animation-delay: 0.24s; }
  .game-card:nth-child(7) { animation-delay: 0.28s; }
  .game-card:nth-child(8) { animation-delay: 0.32s; }
  .game-card:nth-child(9) { animation-delay: 0.36s; }

  /* Card click pulse */
  .game-card.is-launching {
    transform: scale(0.97);
    transition: transform 0.12s ease;
  }

  /* Overlay clip-path expand/collapse */
  #game-overlay {
    /* opacity managed via clip-path visibility; keep opacity:1 always when visible */
  }

  /* Inner content: fade + lift after overlay expands */
  #game-overlay .overlay-inner {
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.25s ease 0.28s, transform 0.25s ease 0.28s;
  }
  #game-overlay.is-open .overlay-inner {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const cards    = document.querySelectorAll('.game-card');
  const overlay  = document.getElementById('game-overlay') as HTMLElement | null;
  const closeBtn = document.getElementById('close-game-btn');
  const titleEl  = document.getElementById('game-overlay-title');
  const contents = document.querySelectorAll('.game-content');
  const siteNav  = document.querySelector('header') as HTMLElement | null;
  let active: string | null = null;
  let activeCardEl: Element | null = null;

  /** Returns a clip-path inset string matching an element's viewport rect */
  function clipForEl(el: Element): string {
    const r   = el.getBoundingClientRect();
    const vw  = window.innerWidth;
    const vh  = window.innerHeight;
    const top    = Math.round(r.top);
    const right  = Math.round(vw - r.right);
    const bottom = Math.round(vh - r.bottom);
    const left   = Math.round(r.left);
    return `inset(${top}px ${right}px ${bottom}px ${left}px round 12px)`;
  }

  function openGame(id: string) {
    active = id;
    const card = document.querySelector(`[data-game="${id}"]`);
    activeCardEl = card;

    // Brief scale-down pulse on the card
    if (card) {
      card.classList.add('is-launching');
      setTimeout(() => card.classList.remove('is-launching'), 150);
    }

    // Set overlay title
    if (card && titleEl) {
      titleEl.textContent = card.querySelector('h3')?.textContent?.trim() ?? id;
    }

    // Show the right game content
    contents.forEach(el => el.classList.add('hidden'));
    const gameEl = document.getElementById(`game-content-${id}`);
    if (gameEl) {
      gameEl.classList.remove('hidden');
      const iframe = gameEl.querySelector('iframe') as HTMLIFrameElement | null;
      if (iframe) iframe.src = iframe.src;
    }

    // Hide navbar
    if (siteNav) siteNav.style.display = 'none';
    document.body.style.overflow = 'hidden';

    if (overlay && card) {
      // 1. Snap overlay to card bounds (no transition)
      overlay.style.transition = 'none';
      overlay.style.clipPath   = clipForEl(card);
      overlay.style.opacity    = '1';
      overlay.style.display    = 'flex';
      overlay.classList.remove('hidden');
      overlay.classList.remove('is-open'); // reset inner content

      // 2. Force reflow so browser registers the start state
      overlay.getBoundingClientRect();

      // 3. Animate expand to full viewport
      overlay.style.transition = 'clip-path 0.42s cubic-bezier(0.22, 1, 0.36, 1)';
      overlay.style.clipPath   = 'inset(0px 0px 0px 0px round 0px)';

      // 4. After expand, reveal inner content
      setTimeout(() => {
        overlay.classList.add('is-open');
        window.dispatchEvent(new Event('resize'));
      }, 100);
    }
  }

  function closeGame() {
    const closingId = active;
    active = null;

    if (overlay) {
      // Fade out inner content immediately
      overlay.classList.remove('is-open');

      // Collapse back to card bounds (or just collapse to centre if card not visible)
      const card = closingId ? document.querySelector(`[data-game="${closingId}"]`) : null;
      const targetClip = card
        ? clipForEl(card)
        : `inset(50% 50% 50% 50% round 12px)`;

      // Short delay so inner content fades first
      setTimeout(() => {
        overlay.style.transition = 'clip-path 0.32s cubic-bezier(0.22, 1, 0.36, 1)';
        overlay.style.clipPath   = targetClip;

        // After collapse, fully hide
        setTimeout(() => {
          overlay.style.display  = 'none';
          overlay.style.clipPath = '';
          overlay.style.transition = '';
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
          contents.forEach(el => el.classList.add('hidden'));
          if (siteNav) siteNav.style.display = '';
        }, 330);
      }, 80);
    }
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-game');
      if (id) openGame(id);
    });
  });

  closeBtn?.addEventListener('click', closeGame);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && active) closeGame();
  });
</script>
