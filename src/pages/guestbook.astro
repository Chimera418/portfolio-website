---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

// Avatar selection: all 45 characters (Original + Pokemon)
const AVATAR_INDICES = Array.from({ length: 45 }, (_, i) => i);
---

<Layout title="Guestbook | Chimera's Realm">
  <Navbar />

  <div class="mt-8 max-w-6xl mx-auto animate-fade-in" id="guestbook-container">
    <!-- Page Header -->
    <section class="mb-10">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
        Guest<span
          class="text-primary font-pixel text-2xl md:text-3xl align-middle"
          >book</span
        >
      </h1>
      <p class="text-lg text-text-muted max-w-xl leading-relaxed mb-4">
        Drop some lore, share some feedback, or just say hi. Every message is
        appreciated!!
        <span class="text-primary font-pixel text-sm">ദ്ദി（• ˕ •マ.ᐟ</span>
      </p>
    </section>

    <!-- Two-column bento layout -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 items-start">
      <!-- Left: Message Wall (3/5 width) -->
      <div class="lg:col-span-3 flex flex-col gap-4">
        <div class="flex items-center justify-between mb-1">
          <h2
            class="text-lg font-semibold text-text-primary flex items-center gap-2"
          >
            <svg
              class="w-5 h-5 text-secondary"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
              ></path>
            </svg>
            Messages
          </h2>
          <span
            id="gb-entry-count"
            data-count="0"
            class="font-pixel text-[9px] text-text-muted">0 entries</span
          >
        </div>

        <div
          id="gb-message-wall"
          class="space-y-3 max-h-[680px] overflow-y-auto pr-1 custom-scroll"
          data-lenis-prevent
        >
          <!-- Populated via LocalStorage on Client Side -->
        </div>

        <!-- Future note -->
        <p class="font-pixel text-[9px] text-text-muted/60 text-center pt-1">
          ✦ more messages incoming as the guestbook fills up ✦
        </p>
      </div>

      <!-- Right: Submit Form (2/5 width) -->
      <div class="lg:col-span-2 lg:sticky lg:top-28">
        <div
          class="bg-surface border-2 border-highlight-med rounded-xl p-6 relative overflow-hidden"
        >
          <!-- Decorative pixel corner accents -->
          <div
            class="absolute top-0 left-0 w-3 h-3 bg-primary rounded-br-md opacity-60"
          >
          </div>
          <div
            class="absolute top-0 right-0 w-3 h-3 bg-secondary rounded-bl-md opacity-60"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 w-3 h-3 bg-tertiary rounded-tr-md opacity-60"
          >
          </div>
          <div
            class="absolute bottom-0 right-0 w-3 h-3 bg-primary rounded-tl-md opacity-60"
          >
          </div>

          <div class="mb-5">
            <h2
              class="text-lg font-semibold text-text-primary mb-1 flex items-center gap-2"
            >
              <svg
                class="w-4 h-4 text-primary"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
                ></path>
              </svg>
              Leave a Note
            </h2>
            <p class="text-xs text-text-muted">
              Your message will appear on the wall instantly.
            </p>
          </div>

          <form id="guestbook-form" class="flex flex-col gap-4" novalidate>
            <!-- Sprite Picker -->
            <div class="flex flex-col gap-2">
              <label
                class="font-pixel text-[9px] text-text-muted uppercase tracking-widest flex items-center gap-2"
              >
                Pick your avatar
                <div
                  class="ml-2 w-10 h-10 rounded-lg bg-overlay flex shrink-0 items-center justify-center overflow-hidden border border-highlight-med"
                >
                  <div
                    id="gb-avatar-preview"
                    class="sprite-avatar"
                    style="--sprite-idx: 0;"
                  >
                  </div>
                </div>
              </label>
              <div
                class="grid grid-cols-5 gap-2 p-3 bg-overlay border border-highlight-med rounded-lg h-48 overflow-y-auto custom-scroll"
                data-lenis-prevent
              >
                {
                  AVATAR_INDICES.map((idx, i) => (
                    <button
                      type="button"
                      data-avatar-idx={idx}
                      class={`avatar-btn h-10 w-full flex items-center justify-center rounded-lg hover:bg-surface-bright transition-all duration-150 border border-transparent ${i === 0 ? "avatar-selected" : ""}`}
                      title={`Avatar ${idx}`}
                      aria-label={`Select avatar ${idx}`}
                    >
                      <div
                        class="sprite-avatar"
                        style={`--sprite-idx: ${idx};`}
                      />
                    </button>
                  ))
                }
              </div>
              <input
                type="hidden"
                id="gb-avatar"
                name="avatar"
                value={AVATAR_INDICES[0]}
              />
            </div>

            <!-- Name -->
            <div class="flex flex-col gap-1.5">
              <label
                for="gb-name"
                class="font-pixel text-[9px] text-text-muted uppercase tracking-widest"
              >
                Name *
              </label>
              <input
                id="gb-name"
                type="text"
                name="name"
                placeholder="Your name"
                maxlength="40"
                required
                class="gb-input bg-overlay border border-highlight-med rounded-lg px-4 py-3 text-sm text-text-primary placeholder-text-muted focus:outline-none focus:border-primary transition-colors duration-200 w-full"
              />
            </div>

            <!-- Social handle (optional) -->
            <div class="flex flex-col gap-1.5 relative">
              <label
                for="gb-handle"
                class="font-pixel text-[9px] text-text-muted uppercase tracking-widest"
              >
                Social handle <span
                  class="text-text-muted/50 normal-case font-sans"
                  >(optional)</span
                >
              </label>
              <div class="relative flex items-center">
                <button
                  type="button"
                  id="gb-platform-btn"
                  class="absolute left-1.5 p-1.5 rounded-md text-text-muted hover:text-text-primary hover:bg-highlight-med/30 transition-all duration-200 flex items-center gap-1 z-10"
                  title="Select platform"
                >
                  <span id="gb-platform-icon">
                    <svg
                      class="w-4 h-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><circle cx="12" cy="12" r="4"></circle><path
                        d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"
                      ></path></svg
                    >
                  </span>
                  <svg
                    class="w-3 h-3 opacity-70"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"></path></svg
                  >
                </button>

                <div
                  id="gb-platform-menu"
                  class="absolute top-full left-0 mt-2 w-36 max-h-[200px] overflow-y-auto overflow-x-hidden bg-surface border border-highlight-med rounded-lg shadow-xl opacity-0 invisible transform -translate-y-2 transition-all duration-200 z-50 platform-menu-scroll"
                >
                  <div class="flex flex-col py-1">
                    <button
                      type="button"
                      data-platform="instagram"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg
                        class="w-4 h-4 text-text-muted"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                        ></rect><path
                          d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                        ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
                        ></line></svg
                      >
                      Instagram
                    </button>
                    <button
                      type="button"
                      data-platform="discord"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg class="w-4 h-4 text-text-muted" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.028zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" /></svg>
                      Discord
                    </button>
                    <button
                      type="button"
                      data-platform="twitter"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg
                        class="w-4 h-4 text-text-muted"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                          d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"
                        ></path></svg
                      >
                      X
                    </button>
                    <button
                      type="button"
                      data-platform="github"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg
                        class="w-4 h-4 text-text-muted"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                          d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                        ></path></svg
                      >
                      GitHub
                    </button>
                    <button
                      type="button"
                      data-platform="linkedin"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg
                        class="w-4 h-4 text-text-muted"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                          d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                        ></path><rect x="2" y="9" width="4" height="12"
                        ></rect><circle cx="4" cy="4" r="2"></circle></svg
                      >
                      LinkedIn
                    </button>
                    <button
                      type="button"
                      data-platform="youtube"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg
                        class="w-4 h-4 text-text-muted"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                          d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"
                        ></path><polygon
                          points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"
                        ></polygon></svg
                      >
                      YouTube
                    </button>
                    <button
                      type="button"
                      data-platform="twitch"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg
                        class="w-4 h-4 text-text-muted"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M21 2H3v16h5v4l4-4h5l4-4V2zm-10 9V7m5 4V7"
                        ></path></svg
                      >
                      Twitch
                    </button>
                    <button
                      type="button"
                      data-platform="spotify"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg
                        class="w-4 h-4 text-text-muted"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                          d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.54.659.3 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.84.24 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.6.18-1.2.72-1.38 4.2-1.26 11.28-1.02 15.721 1.62.539.3.719 1.02.419 1.56-.239.54-.839.72-1.56.3z"
                        ></path></svg
                      >
                      Spotify
                    </button>
                    <button
                      type="button"
                      data-platform="other"
                      class="platform-option flex items-center gap-3 px-3 py-2 hover:bg-highlight-med/30 text-sm text-text-primary transition-colors"
                    >
                      <svg
                        class="w-4 h-4 text-text-muted"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="12" cy="12" r="4"></circle><path
                          d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"
                        ></path></svg
                      >
                      Other
                    </button>
                  </div>
                </div>

                <input
                  type="hidden"
                  id="gb-platform-input"
                  name="platform"
                  value=""
                />

                <input
                  id="gb-handle"
                  type="text"
                  name="handle"
                  placeholder="@you"
                  maxlength="40"
                  class="gb-input bg-overlay border border-highlight-med rounded-lg pl-14 pr-4 py-3 text-sm text-text-primary placeholder-text-muted focus:outline-none focus:border-secondary transition-colors duration-200 w-full"
                />
              </div>
            </div>

            <!-- Website (optional) -->
            <div class="flex flex-col gap-1.5">
              <label
                for="gb-website"
                class="font-pixel text-[9px] text-text-muted uppercase tracking-widest"
              >
                Website <span class="text-text-muted/50 normal-case font-sans"
                  >(optional — makes your name a link)</span
                >
              </label>
              <input
                id="gb-website"
                type="url"
                name="website"
                placeholder="https://yoursite.com"
                maxlength="120"
                class="gb-input bg-overlay border border-highlight-med rounded-lg px-4 py-3 text-sm text-text-primary placeholder-text-muted focus:outline-none focus:border-tertiary transition-colors duration-200 w-full"
              />
            </div>

            <!-- Message -->
            <div class="flex flex-col gap-1.5">
              <label
                for="gb-message"
                class="font-pixel text-[9px] text-text-muted uppercase tracking-widest"
              >
                Message *
              </label>
              <textarea
                id="gb-message"
                name="message"
                placeholder="Say something nice..."
                maxlength="280"
                rows="3"
                required
                class="gb-input bg-overlay border border-highlight-med rounded-lg px-4 py-3 text-sm text-text-primary placeholder-text-muted focus:outline-none focus:border-primary transition-colors duration-200 w-full resize-none"
              ></textarea>
              <div class="flex justify-end">
                <span
                  id="gb-char-count"
                  class="font-pixel text-[9px] text-text-muted">0 / 280</span
                >
              </div>
            </div>

            <!-- Submit button -->
            <button
              id="gb-submit"
              type="submit"
              class="relative overflow-hidden w-full bg-primary/10 border border-primary/40 hover:bg-primary/20 hover:border-primary text-primary font-pixel text-[10px] uppercase tracking-widest py-3 px-6 rounded-lg transition-all duration-300 flex items-center justify-center gap-2"
            >
              <span id="gb-btn-text">Send Message</span>
              <svg
                class="w-3 h-3"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
              <!-- Shimmer overlay -->
              <div
                id="gb-shimmer"
                class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-primary/20 to-transparent hidden pointer-events-none"
              >
              </div>
            </button>

            <!-- Status message -->
            <div
              id="gb-status"
              class="hidden font-pixel text-[9px] text-center py-2 px-3 rounded-lg border"
            >
            </div>
          </form>
        </div>

        <!-- Pixel bar decoration -->
        <div
          class="mt-4 bg-overlay border-2 border-highlight-med rounded-xl p-4 flex items-center gap-3"
        >
          <div class="flex gap-1 items-end">
            {
              ["h-6", "h-4", "h-8", "h-5", "h-7", "h-3", "h-6"].map((h, i) => (
                <div
                  class={`w-2 ${h} rounded-sm opacity-70`}
                  style={`background: var(--${["primary", "secondary", "tertiary", "primary", "secondary", "tertiary", "primary"][i]})`}
                />
              ))
            }
          </div>
          <p class="font-pixel text-[9px] text-text-muted leading-relaxed">
            Be the first to<br />fill the wall ✦
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Custom scrollbar */
  .custom-scroll::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scroll::-webkit-scrollbar-track {
    background: var(--overlay);
    border-radius: 2px;
  }
  .custom-scroll::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--primary) 80%, transparent);
    border-radius: 2px;
  }
  .custom-scroll::-webkit-scrollbar-thumb:hover {
    background: var(--primary);
  }

  /* Input focus ring */
  .gb-input:focus {
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent);
  }

  /* 32px Sprite Logic */
  .sprite-avatar {
    background-image: url("/combined_avatars.png");
    background-repeat: no-repeat;

    width: 32px;
    height: 32px;

    /* 32px row offset based on index */
    background-position: 0px calc(var(--sprite-idx) * -32px);

    image-rendering: pixelated;
  }

  /* Avatar picker selected state */
  .avatar-btn {
    position: relative;
    cursor: pointer;
  }
  .avatar-selected {
    background: color-mix(in srgb, var(--primary) 20%, transparent);
    border-color: color-mix(in srgb, var(--primary) 60%, transparent);
  }

  /* Shimmer animation */
  @keyframes shimmer {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(200%);
    }
  }
  .shimmer-active {
    animation: shimmer 0.8s ease-in-out;
  }

  /* Platform menu custom scrollbar */
  .platform-menu-scroll::-webkit-scrollbar {
    width: 4px;
  }
  .platform-menu-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .platform-menu-scroll::-webkit-scrollbar-thumb {
    background-color: color-mix(in srgb, var(--text-muted) 30%, transparent);
    border-radius: 4px;
  }
  .platform-menu-scroll::-webkit-scrollbar-thumb:hover {
    background-color: color-mix(in srgb, var(--text-muted) 50%, transparent);
  }

  /* Message card hover glow */
  .message-card:hover {
    box-shadow: 0 0 16px color-mix(in srgb, var(--secondary) 8%, transparent);
  }
</style>

<script>
  // ── Avatar picker ─────────────────────────────────────────────
  const avatarInput = document.getElementById("gb-avatar") as HTMLInputElement;
  const avatarPreview = document.getElementById(
    "gb-avatar-preview",
  ) as HTMLElement;
  const avatarButtons =
    document.querySelectorAll<HTMLButtonElement>(".avatar-btn");

  avatarButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      // Deselect all
      avatarButtons.forEach((b) => b.classList.remove("avatar-selected"));
      // Select clicked
      btn.classList.add("avatar-selected");
      const chosen = btn.dataset.avatarIdx ?? "0";
      avatarInput.value = chosen;
      avatarPreview.style.setProperty("--sprite-idx", chosen);
    });
  });

  // ── Form logic ────────────────────────────────────────────────
  const form = document.getElementById("guestbook-form") as HTMLFormElement;
  const nameEl = document.getElementById("gb-name") as HTMLInputElement;
  const handleEl = document.getElementById("gb-handle") as HTMLInputElement;
  const websiteEl = document.getElementById("gb-website") as HTMLInputElement;
  const msgEl = document.getElementById("gb-message") as HTMLTextAreaElement;
  const countEl = document.getElementById("gb-char-count") as HTMLSpanElement;
  const statusEl = document.getElementById("gb-status") as HTMLDivElement;
  const shimmer = document.getElementById("gb-shimmer") as HTMLDivElement;
  const btnText = document.getElementById("gb-btn-text") as HTMLSpanElement;
  const wallEl = document.getElementById("gb-message-wall") as HTMLDivElement;
  const entryCountEl = document.getElementById(
    "gb-entry-count",
  ) as HTMLSpanElement;

  function timeAgo(dateString: string) {
    const date = new Date(dateString);
    const now = new Date();
    const seconds = Math.round((now.getTime() - date.getTime()) / 1000);
    const minutes = Math.round(seconds / 60);
    const hours = Math.round(minutes / 60);
    const days = Math.round(hours / 24);

    if (seconds < 60) return "Just now";
    if (minutes < 60) return `${minutes}m ago`;
    if (hours < 24) return `${hours}h ago`;
    if (days < 30) return `${days}d ago`;
    return date.toLocaleDateString();
  }

  function createMessageHTML(msg: any) {
    // Escape basic HTML tags to prevent XSS
    const escapeHTML = (str: string) =>
      str.replace(
        /[&<>'"]/g,
        (tag) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            "'": "&#39;",
            '"': "&quot;",
          })[tag] || tag,
      );

    const safeName = escapeHTML(msg.name);
    const safeMsg = escapeHTML(msg.message);
    const safeHandle = msg.handle ? escapeHTML(msg.handle) : "";
    const safeWebsite = msg.website ? escapeHTML(msg.website) : "";
    const dateDisplay = msg.created_at
      ? timeAgo(msg.created_at)
      : msg.date || "Just now";

    const getPlatformIcon = (platform: string) => {
      const p = platform?.toLowerCase() || "";
      switch (p) {
        case "twitter":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path></svg>`;
        case "github":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>`;
        case "linkedin":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>`;
        case "youtube":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>`;
        case "dribbble":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"></path></svg>`;
        case "twitch":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2H3v16h5v4l4-4h5l4-4V2zm-10 9V7m5 4V7"></path></svg>`;
        case "spotify":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.54.659.3 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.84.24 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.6.18-1.2.72-1.38 4.2-1.26 11.28-1.02 15.721 1.62.539.3.719 1.02.419 1.56-.239.54-.839.72-1.56.3z"/></svg>`;
        case "instagram":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`;
        case "discord":
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.028zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" /></svg>`;
        default:
          return `<svg class="w-[14px] h-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"></path></svg>`;
      }
    };

    const getPlatformUrl = (platform: string, handle: string) => {
      const p = platform?.toLowerCase() || "";
      const cleanHandle = handle.replace(/^@/, "");
      switch (p) {
        case "twitter":
          return `https://x.com/${cleanHandle}`;
        case "github":
          return `https://github.com/${cleanHandle}`;
        case "linkedin":
          return `https://linkedin.com/in/${cleanHandle}`;
        case "youtube":
          return `https://youtube.com/@${cleanHandle}`;
        case "dribbble":
          return `https://dribbble.com/${cleanHandle}`;
        case "twitch":
          return `https://twitch.tv/${cleanHandle}`;
        case "spotify":
          return `https://open.spotify.com/user/${cleanHandle}`;
        case "instagram":
          return `https://instagram.com/${cleanHandle}`;
        case "discord":
          return `https://discord.com/users/${cleanHandle}`;
        case "other":
          return handle.startsWith("http") ? handle : `https://${cleanHandle}`;
        default:
          return `https://x.com/${cleanHandle}`; // fallback for generic handles
      }
    };

    return `
      <div class="message-card bg-surface border-2 border-highlight-med rounded-xl p-5 hover:border-secondary/50 transition-all duration-300 group animate-fade-in">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 flex-shrink-0 bg-overlay border border-highlight-med rounded-lg flex items-center justify-center overflow-hidden group-hover:scale-110 transition-transform duration-200">
             <div class="sprite-avatar" style="--sprite-idx: ${msg.avatarIdx};"></div>
          </div>
          <div class="flex-grow min-w-0">
            <div class="flex items-center justify-between gap-2 mb-1 flex-wrap">
              <div class="flex items-center gap-2 flex-wrap">
                ${
                  safeWebsite
                    ? `
                  <a href="${safeWebsite}" target="_blank" rel="noopener noreferrer" class="font-semibold text-sm text-secondary hover:text-primary hover:underline decoration-2 decoration-dotted underline-offset-[4px] transition-all duration-200">
                    ${safeName}
                  </a>
                `
                    : `
                  <span class="font-semibold text-text-primary text-sm">${safeName}</span>
                `
                }
                ${
                  safeHandle
                    ? msg.platform?.toLowerCase() === "discord"
                      ? `
                  <button type="button" class="discord-guest-copy-btn flex items-center gap-1.5 text-text-muted hover:text-[#5865F2] transition-colors duration-200" data-handle="${safeHandle}">
                    ${getPlatformIcon(msg.platform)}
                    <span class="relative group/discord">
                      <span class="font-pixel text-[10px] tracking-wide mt-0.5 handle-text inline-block">${safeHandle}</span>
                      <span class="absolute -top-6 left-1/2 -translate-x-1/2 bg-surface border border-highlight-med text-text-primary font-pixel text-[8px] px-2 py-1 rounded opacity-0 invisible group-hover/discord:opacity-100 group-hover/discord:visible transition-all duration-200 whitespace-nowrap z-10 pointer-events-none">click to copy</span>
                    </span>
                  </button>
                `
                      : `
                  <a href="${getPlatformUrl(msg.platform, safeHandle)}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-text-muted hover:text-primary transition-colors duration-200" title="${safeHandle}">
                    ${getPlatformIcon(msg.platform)}
                    <span class="font-pixel text-[10px] tracking-wide mt-0.5">${safeHandle}</span>
                  </a>
                `
                    : ""
                }
              </div>
              <span class="font-pixel text-[9px] text-text-muted flex-shrink-0 mt-[2px]">${dateDisplay}</span>
            </div>
            <p class="text-text-muted text-sm leading-relaxed">${safeMsg}</p>
          </div>
        </div>
      </div>
    `;
  }

  function updateEntryCount(totalCount: number) {
    if (!entryCountEl) return;
    entryCountEl.textContent = `${totalCount} entries`;
    entryCountEl.setAttribute("data-count", totalCount.toString());
  }

  async function loadMessages() {
    try {
      // 1. Instantly load from cache
      const cached = localStorage.getItem("guestbook_cache");
      if (cached) {
        const cachedMessages = JSON.parse(cached);
        wallEl.innerHTML = "";
        cachedMessages.forEach((msg: any) => {
          wallEl.insertAdjacentHTML("beforeend", createMessageHTML(msg));
        });
        updateEntryCount(cachedMessages.length);
      }

      // 2. Fetch fresh data in the background
      const res = await fetch("/api/guestbook");
      if (!res.ok) throw new Error("Failed to fetch");
      const messages = await res.json();

      // 3. Save to cache
      localStorage.setItem("guestbook_cache", JSON.stringify(messages));

      // 4. Update UI with fresh data
      wallEl.innerHTML = "";
      messages.forEach((msg: any) => {
        wallEl.insertAdjacentHTML("beforeend", createMessageHTML(msg));
      });
      updateEntryCount(messages.length);
    } catch (e) {
      console.error(e);
      if (!localStorage.getItem("guestbook_cache")) {
        wallEl.innerHTML =
          '<p class="text-text-muted text-sm text-center">Failed to load messages. Please try again later.</p>';
      }
    }
  }

  // Live char counter
  msgEl?.addEventListener("input", () => {
    const len = msgEl.value.length;
    countEl.textContent = `${len} / 280`;
    countEl.style.color = len > 250 ? "var(--primary)" : "var(--text-muted)";
  });

  // Form submit
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const name = nameEl.value.trim();
    const handle = handleEl?.value.trim() || "";
    let website = websiteEl?.value.trim() || "";
    const message = msgEl.value.trim();
    const avatarIdx = avatarInput.value;
    const platformInputEl = document.getElementById(
      "gb-platform-input",
    ) as HTMLInputElement;
    let platform = platformInputEl?.value || "";
    if (handle && !platform) {
      platform = "instagram";
    }

    if (!name || !message) {
      showStatus("Name and message are required.", "error");
      return;
    }

    // Basic URL fix
    if (website && !/^https?:\/\//i.test(website)) {
      website = "https://" + website;
    }

    // Shimmer feedback
    btnText.textContent = "Posting…";
    shimmer.classList.remove("hidden");
    shimmer.classList.add("shimmer-active");

    try {
      const res = await fetch("/api/guestbook", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name,
          handle,
          website,
          message,
          avatarIdx,
          platform,
        }),
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || "Failed to post message");
      }

      const newMsg = await res.json();

      if (wallEl) {
        wallEl.insertAdjacentHTML("afterbegin", createMessageHTML(newMsg));
      }

      // Update cache with the new message
      try {
        const cached = JSON.parse(
          localStorage.getItem("guestbook_cache") || "[]",
        );
        localStorage.setItem(
          "guestbook_cache",
          JSON.stringify([newMsg, ...cached]),
        );
      } catch (e) {}

      const currentCount = parseInt(
        entryCountEl.getAttribute("data-count") || "0",
      );
      updateEntryCount(currentCount + 1);

      showStatus("Message posted successfully! ✨", "success");
      form.reset();
      countEl.textContent = "0 / 280";

      // Reset platform picker
      const platformInputEl = document.getElementById(
        "gb-platform-input",
      ) as HTMLInputElement;
      const platformIcon = document.getElementById(
        "gb-platform-icon",
      ) as HTMLSpanElement;
      if (platformInputEl) platformInputEl.value = "";
      if (platformIcon)
        platformIcon.innerHTML = `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"></path></svg>`;

      // Reset avatar picker
      avatarButtons.forEach((b) => b.classList.remove("avatar-selected"));
      avatarButtons[0]?.classList.add("avatar-selected");
      avatarInput.value = avatarButtons[0]?.dataset.avatarIdx ?? "0";
      avatarPreview.style.setProperty("--sprite-idx", "0");
    } catch (err) {
      console.error(err);
      showStatus("Failed to send message. Please try again.", "error");
    } finally {
      shimmer.classList.remove("shimmer-active");
      shimmer.classList.add("hidden");
      btnText.textContent = "Send Message";
    }
  });

  function showStatus(msg: string, type: "success" | "error") {
    statusEl.textContent = msg;
    statusEl.classList.remove("hidden");
    if (type === "success") {
      statusEl.style.color = "var(--secondary)";
      statusEl.style.borderColor =
        "color-mix(in srgb, var(--secondary) 30%, transparent)";
      statusEl.style.background =
        "color-mix(in srgb, var(--secondary) 8%, transparent)";
    } else {
      statusEl.style.color = "var(--primary)";
      statusEl.style.borderColor =
        "color-mix(in srgb, var(--primary) 30%, transparent)";
      statusEl.style.background =
        "color-mix(in srgb, var(--primary) 8%, transparent)";
    }
    setTimeout(() => statusEl.classList.add("hidden"), 5000);
  }

  // ── Platform Dropdown Logic ────────────────────────────────────
  const platformBtn = document.getElementById(
    "gb-platform-btn",
  ) as HTMLButtonElement;
  const platformMenu = document.getElementById(
    "gb-platform-menu",
  ) as HTMLDivElement;
  const platformInputEl = document.getElementById(
    "gb-platform-input",
  ) as HTMLInputElement;
  const platformIcon = document.getElementById(
    "gb-platform-icon",
  ) as HTMLSpanElement;

  // Toggle dropdown on button click
  platformBtn?.addEventListener("click", () => {
    const isExpanded = platformMenu.classList.contains("opacity-100");
    if (isExpanded) {
      closeDropdown();
    } else {
      platformMenu.classList.remove("opacity-0", "invisible", "-translate-y-2");
      platformMenu.classList.add("opacity-100", "visible", "translate-y-0");
    }
  });

  function closeDropdown() {
    platformMenu?.classList.remove("opacity-100", "visible", "translate-y-0");
    platformMenu?.classList.add("opacity-0", "invisible", "-translate-y-2");
  }

  // Close dropdown on outside click
  document.addEventListener("click", (e) => {
    if (
      !platformBtn?.contains(e.target as Node) &&
      !platformMenu?.contains(e.target as Node)
    ) {
      closeDropdown();
    }
  });

  // Select platform option
  document.querySelectorAll(".platform-option").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const platform = target.dataset.platform || "instagram";
      const svg = target.querySelector("svg")?.outerHTML || "";

      if (platformInputEl) platformInputEl.value = platform;
      if (platformIcon) platformIcon.innerHTML = svg;
      closeDropdown();
    });
  });

  // Enable/disable based on handle input
  handleEl?.addEventListener("input", () => {
    if (handleEl.value.trim().length > 0) {
      if (!platformInputEl.value) {
        platformInputEl.value = "instagram";
        if (platformIcon)
          platformIcon.innerHTML = `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`;
      }
    } else {
      // Clear platform if handle is emptied
      platformInputEl.value = "";
      if (platformIcon)
        platformIcon.innerHTML = `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"></path></svg>`;
      closeDropdown();
    }
  });

  // Handle Discord click-to-copy
  document.addEventListener("click", (e) => {
    const target = e.target;
    const btn = target && target.closest ? target.closest(".discord-guest-copy-btn") : null;
    if (btn) {
      const handle = btn.getAttribute("data-handle");
      if (handle) {
        navigator.clipboard.writeText(handle).catch(() => {});
        const hint = btn.querySelector(".handle-text");
        if (hint) {
          hint.textContent = "copied!";
          hint.classList.add("text-secondary");
          setTimeout(() => {
            hint.textContent = handle;
            hint.classList.remove("text-secondary");
          }, 2000);
        }
      }
    }
  });

  // Initialize
  document.addEventListener("DOMContentLoaded", loadMessages);
</script>
