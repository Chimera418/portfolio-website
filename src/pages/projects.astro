---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ProjectGridCard from '../components/ProjectGridCard.astro';

// Bypass Astro content collections and fetch directly
const projectFiles = Object.values(import.meta.glob('../content/projects/*.md', { eager: true }));

const projects = projectFiles.map((file: any) => ({
  id: file.file.split('/').pop().replace('.md', ''),
  data: file.frontmatter
})).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Layout title="Projects | Chimera">
  <Navbar />
  
  <div class="mt-8 max-w-6xl mx-auto space-y-12 animate-fade-in">
    <!-- Header -->
    <section class="text-center max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
        Project <span class="text-secondary font-pixel text-2xl md:text-3xl align-middle">Database</span>
      </h1>
      <p class="text-lg text-text-muted">
        A collection of my recent work, experiments, and open-source contributions. 
      </p>
    </section>

    <!-- Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map(project => (
        <ProjectGridCard 
          title={project.data.title}
          description={project.data.description}
          tags={project.data.tags}
          link={project.data.link}
          github={project.data.github}
          slug={project.id}
          date={project.data.date}
        />
      ))}
    </section>
  </div>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
